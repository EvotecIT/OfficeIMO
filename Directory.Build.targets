<Project>
  <!-- Production projects inherit TreatWarningsAsErrors=true from Directory.Build.props.
       Tests and benchmarks still show warnings, but warnings do not block local or CI validation. -->
  <PropertyGroup Condition="
      '$(IsTestProject)' == 'true'
      Or '$(MSBuildProjectName)' == 'OfficeIMO.Word.Tests'
      Or '$(MSBuildProjectName)' == 'OfficeIMO.CSV.Tests'
      Or '$(MSBuildProjectName)' == 'OfficeIMO.VerifyTests'
      Or '$(MSBuildProjectName)' == 'OfficeIMO.MarkdownRenderer.Wpf.Tests'
      Or $([System.String]::Copy('$(MSBuildProjectName)').Contains('.Benchmarks'))">
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <!-- Examples are executable documentation. Keep nullable enabled so annotated samples do not emit CS8632 noise. -->
  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'OfficeIMO.Examples'">
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- Reader packages with an explicit published baseline are checked for source/binary compatibility.
       New packages omit the baseline until their first public release. -->
  <PropertyGroup Condition="
      $([System.String]::Copy('$(MSBuildProjectName)').StartsWith('OfficeIMO.Reader'))
      And '$(IsPackable)' != 'false'
      And '$(PackageValidationBaselineVersion)' != ''">
    <EnablePackageValidation>true</EnablePackageValidation>
  </PropertyGroup>

  <ItemGroup Condition="
      $([System.String]::Copy('$(MSBuildProjectName)').StartsWith('OfficeIMO.Reader'))
      And '$(IsPackable)' != 'false'
      And '$(PackageValidationBaselineVersion)' != ''
      And !$([MSBuild]::IsOsPlatform('Windows'))">
    <PackageValidationBaselineFrameworkToIgnore Include="net472" />
  </ItemGroup>
</Project>
