<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>Dependency-light contracts, routing, processing, and normalized document models for modular OfficeIMO readers.</Description>
    <AssemblyName>OfficeIMO.Reader.Core</AssemblyName>
    <AssemblyTitle>OfficeIMO.Reader.Core</AssemblyTitle>
    <VersionPrefix>2.0.1</VersionPrefix>
    <TargetFrameworks>netstandard2.0;net8.0;net10.0</TargetFrameworks>
    <TargetFrameworks Condition=" '$([MSBuild]::IsOsPlatform(`Windows`))' ">$(TargetFrameworks);net472</TargetFrameworks>
    <GeneratePackageOnBuild>False</GeneratePackageOnBuild>

    <Company>Evotec</Company>
    <Authors>Przemyslaw Klys</Authors>
    <PackageId>OfficeIMO.Reader.Core</PackageId>
    <PackageTags>reader;ingestion;rag;document;contracts;routing;officeimo</PackageTags>
    <PackageProjectUrl>https://github.com/EvotecIT/OfficeIMO</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/EvotecIT/OfficeIMO</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <LangVersion>Latest</LangVersion>
    <Nullable>enable</Nullable>
    <DefineConstants>$(DefineConstants);OFFICEIMO_READER_CORE</DefineConstants>
    <GenerateDocumentationFile>True</GenerateDocumentationFile>
    <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0' Or '$(TargetFramework)' == 'net472'">
    <PackageReference Include="System.Text.Json" Version="[10.0.7,11.0.0)" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\OfficeIMO.SharedSource\Compound\OfficeCompoundDocumentDetector.cs" Link="Internal\Compound\OfficeCompoundDocumentDetector.cs" />
    <Compile Include="..\OfficeIMO.SharedSource\Compound\OfficeCompoundFile.cs" Link="Internal\Compound\OfficeCompoundFile.cs" />
    <Compile Include="..\OfficeIMO.SharedSource\Compound\OfficeCompoundFileEntry.cs" Link="Internal\Compound\OfficeCompoundFileEntry.cs" />
    <Compile Include="..\OfficeIMO.SharedSource\Compound\OfficeCompoundFileReader.cs" Link="Internal\Compound\OfficeCompoundFileReader.cs" />
    <Compile Include="..\OfficeIMO.SharedSource\Compound\OfficeCompoundFileReader.Inspection.cs" Link="Internal\Compound\OfficeCompoundFileReader.Inspection.cs" />
    <None Include="README.md">
      <Pack>True</Pack>
      <PackagePath>README.md</PackagePath>
    </None>
    <None Include="Schemas\officeimo.document.read-result.v5.schema.json">
      <Pack>True</Pack>
      <PackagePath>schemas\officeimo.document.read-result.v5.schema.json</PackagePath>
    </None>
    <EmbeddedResource Include="Schemas\officeimo.document.read-result.v5.schema.json">
      <LogicalName>OfficeIMO.Reader.Schemas.officeimo.document.read-result.v5.schema.json</LogicalName>
    </EmbeddedResource>
    <None Include="Schemas\officeimo.document.read-result.v6.schema.json">
      <Pack>True</Pack>
      <PackagePath>schemas\officeimo.document.read-result.v6.schema.json</PackagePath>
    </None>
    <EmbeddedResource Include="Schemas\officeimo.document.read-result.v6.schema.json">
      <LogicalName>OfficeIMO.Reader.Schemas.officeimo.document.read-result.v6.schema.json</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <Using Include="System" />
    <Using Include="System.Collections.Generic" />
    <Using Include="System.IO" />
    <Using Include="System.Linq" />
    <Using Include="System.Text" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="OfficeIMO.Reader.Tests" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Email" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Word" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Excel" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.PowerPoint" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Markdown" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.AsciiDoc" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Csv" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Epub" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Html" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Image" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Json" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Notebook" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.OpenDocument" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.OneNote" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Pdf" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Rtf" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Subtitles" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Visio" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Web" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Xml" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Yaml" />
    <InternalsVisibleTo Include="OfficeIMO.Reader.Zip" />
  </ItemGroup>
</Project>
