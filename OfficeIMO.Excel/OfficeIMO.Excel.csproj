<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Description>An Open Source cross-platform .NET library providing an easy way to create
            Excel documents.</Description>
        <AssemblyName>OfficeIMO.Excel</AssemblyName>
        <AssemblyTitle>OfficeIMO.Excel</AssemblyTitle>

        <VersionPrefix>0.6.51</VersionPrefix>
        <TargetFrameworks>netstandard2.0;net8.0;net10.0</TargetFrameworks>
        <TargetFrameworks Condition=" '$([MSBuild]::IsOsPlatform(`Windows`))' ">
            $(TargetFrameworks);net472</TargetFrameworks>
        <GeneratePackageOnBuild>False</GeneratePackageOnBuild>

        <Company>Evotec</Company>
        <Authors>Przemyslaw Klys</Authors>

        <PackageId>OfficeIMO.Excel</PackageId>
        <PackageTags>
            docx;net60;excel;office;openxml;net472;net50;netstandard;netstandard2.0,netstandard2.1;net70</PackageTags>
        <PackageProjectUrl>https://github.com/EvotecIT/OfficeIMO</PackageProjectUrl>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <DelaySign>False</DelaySign>
        <IsPublishable>True</IsPublishable>
        <Copyright>(c) 2011 - 2024 Przemyslaw Klys @ Evotec. All rights reserved.</Copyright>
        <PackageIcon>OfficeIMO.png</PackageIcon>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <RepositoryUrl>https://github.com/EvotecIT/OfficeIMO</RepositoryUrl>
        <DebugType>portable</DebugType>
        <LangVersion>Latest</LangVersion>
        <Nullable>enable</Nullable>
        <EnableTrimmingPolyfills>true</EnableTrimmingPolyfills>
        <GenerateDocumentationFile>True</GenerateDocumentationFile>
        <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="DocumentFormat.OpenXml" Version="[3.5.1, 4.0.0)" />
    </ItemGroup>

    <ItemGroup>
        <Compile Include="..\OfficeIMO.Shared\OfficeEncryption.cs" Link="Shared\OfficeEncryption.cs" />
        <Compile Include="..\OfficeIMO.Shared\OfficeEncryption.AgileDescriptor.cs" Link="Shared\OfficeEncryption.AgileDescriptor.cs" />
        <Compile Include="..\OfficeIMO.Shared\OfficeEncryption.CompoundFile.cs" Link="Shared\OfficeEncryption.CompoundFile.cs" />
        <Compile Include="..\OfficeIMO.Shared\Compound\OfficeCompoundFile.cs" Link="Shared\Compound\OfficeCompoundFile.cs" />
        <Compile Include="..\OfficeIMO.Shared\Compound\OfficeCompoundFileEntry.cs" Link="Shared\Compound\OfficeCompoundFileEntry.cs" />
        <Compile Include="..\OfficeIMO.Shared\Compound\OfficeCompoundFileReader.cs" Link="Shared\Compound\OfficeCompoundFileReader.cs" />
        <Compile Include="..\OfficeIMO.Shared\Compound\OfficeCompoundFileWriter.cs" Link="Shared\Compound\OfficeCompoundFileWriter.cs" />
        <Compile Include="..\OfficeIMO.Shared\Ole\OfficeOlePropertySection.cs" Link="Shared\Ole\OfficeOlePropertySection.cs" />
        <Compile Include="..\OfficeIMO.Shared\Ole\OfficeOlePropertySetReader.cs" Link="Shared\Ole\OfficeOlePropertySetReader.cs" />
        <Compile Include="..\OfficeIMO.Shared\Ole\OfficeOlePropertyValue.cs" Link="Shared\Ole\OfficeOlePropertyValue.cs" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\OfficeIMO.Drawing\OfficeIMO.Drawing.csproj" />
        <ProjectReference Include="..\OfficeIMO.CSV\OfficeIMO.CSV.csproj" />
    </ItemGroup>

    <ItemGroup
        Condition="'$(TargetFramework)' == 'netstandard2.0' Or '$(TargetFramework)' == 'net472'">
        <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" Version="10.0.8" />
        <PackageReference Include="System.Text.Json" Version="[10.0.7,11.0.0)" />
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
        <Reference Include="System.Net.Http" />
        <Reference Include="System.IO.Compression" />
        <Reference Include="System.IO.Compression.FileSystem" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="System" />
        <Using Include="System.Text" />
        <Using Include="System.Collections.Generic" />
        <Using Include="System.Collections" />
        <Using Include="System.Linq" />
        <Using Include="System.IO" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\Assets\OfficeIMO.png">
            <Pack>True</Pack>
            <PackagePath>\</PackagePath>
        </None>
        <None Include="README.md">
            <Pack>True</Pack>
            <PackagePath>README.md</PackagePath>
        </None>
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Include="Resources\chart-style-251.xml" />
        <EmbeddedResource Include="Resources\chart-colors-10.xml" />
        <EmbeddedResource Include="Resources\theme1.xml" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="OfficeIMO.Tests" />
    </ItemGroup>

</Project>
