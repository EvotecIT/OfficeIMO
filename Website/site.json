{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/main/schemas/powerforge.web.sitespec.schema.json",
  "SchemaVersion": 1,
  "Name": "OfficeIMO",
  "BaseUrl": "https://officeimo.com",
  "DefaultTheme": "officeimo",
  "Features": ["docs", "apiDocs", "blog", "search", "notFound"],
  "TrailingSlash": "always",
  "ContentRoot": "content",
  "ProjectsRoot": "projects",
  "ThemesRoot": "themes",
  "DataRoot": "data",
  "Sources": [
    {
      "Repo": "EvotecIT/PSWriteOffice",
      "Slug": "pswriteoffice",
      "Destination": "./projects/pswriteoffice"
    }
  ],
  "StaticAssets": [{ "Source": "static" }],
  "Collections": [
    {
      "Name": "pages",
      "Input": "content/pages",
      "Output": "/",
      "DefaultLayout": "home",
      "UseToc": false,
      "Include": ["*.md", "**/*.md"]
    },
    {
      "Name": "products",
      "Input": "content/products",
      "Output": "/products",
      "DefaultLayout": "product",
      "UseToc": false,
      "Include": ["*.md", "**/*.md"]
    },
    {
      "Name": "blog",
      "Preset": "blog",
      "Input": "content/blog",
      "Output": "/blog",
      "DefaultLayout": "blog-post",
      "ListLayout": "page",
      "UseToc": false,
      "EditorialCards": {
        "ImageAspect": "16/9",
        "ImageFit": "cover",
        "ImagePosition": "center",
        "GridClass": "imo-editorial-list imo-editorial-list-blog",
        "CardClass": "imo-editorial-card imo-editorial-card-blog"
      },
      "Include": ["*.md", "**/*.md"]
    },
    {
      "Name": "docs",
      "Input": "content/docs",
      "Output": "/docs",
      "DefaultLayout": "docs",
      "UseToc": true,
      "TocFile": "content/docs/toc.json",
      "Include": ["*.md", "**/*.md"]
    }
  ],
  "Taxonomies": [
    {
      "Name": "tags",
      "BasePath": "/tags",
      "ListLayout": "page",
      "TermLayout": "page"
    },
    {
      "Name": "categories",
      "BasePath": "/categories",
      "ListLayout": "page",
      "TermLayout": "page"
    }
  ],
  "Head": {
    "Links": [
      { "Rel": "icon", "Href": "/favicon.svg", "Type": "image/svg+xml" }
    ]
  },
  "Seo": {
    "CrawlPolicy": {
      "Enabled": true,
      "DefaultRobots": "index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1"
    }
  },
  "Social": {
    "Enabled": true,
    "SiteName": "OfficeIMO",
    "Image": "/images/officeimo-social.png",
    "TwitterCard": "summary_large_image",
    "AutoGenerateCards": true,
    "GeneratedCardsPath": "/assets/social/generated",
    "GeneratedCardWidth": 1200,
    "GeneratedCardHeight": 630,
    "GeneratedCardStyle": "default",
    "GeneratedCardVariant": "standard",
    "GeneratedCardStylesByCollection": {
      "pages": "default",
      "docs": "docs",
      "blog": "editorial",
      "products": "default"
    },
    "GeneratedCardVariantsByCollection": {
      "pages": "hero",
      "docs": "compact",
      "blog": "compact",
      "products": "hero"
    }
  },
  "StructuredData": {
    "Enabled": true,
    "Breadcrumbs": true,
    "OrganizationLegalName": "Evotec Services sp. z o.o.",
    "OrganizationDescription": "Open source .NET libraries for creating, reading, and editing Office documents without Microsoft Office.",
    "OrganizationLogo": "https://officeimo.com/favicon.svg",
    "OrganizationSameAs": [
      "https://github.com/EvotecIT/OfficeIMO",
      "https://github.com/EvotecIT/PSWriteOffice",
      "https://evotec.xyz",
      "https://evo.yt/discord"
    ],
    "OrganizationEmail": "support@evotec.xyz",
    "OrganizationContactUrl": "https://officeimo.com/docs/getting-started/"
  },
  "AgentReadiness": {
    "Enabled": true,
    "HeadersPath": "_headers",
    "LinkHeaders": true,
    "Robots": true,
    "SecurityHeaders": {
      "Enabled": true,
      "ContentSecurityPolicyValue": "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self'; frame-src 'self' blob:; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
    },
    "ContentSignals": {
      "Enabled": true,
      "Search": true,
      "AiInput": true,
      "AiTrain": false
    },
    "BotRules": [
      { "UserAgent": "GPTBot", "Allow": "/" },
      { "UserAgent": "ChatGPT-User", "Allow": "/" },
      { "UserAgent": "OAI-SearchBot", "Allow": "/" },
      { "UserAgent": "ClaudeBot", "Allow": "/" },
      { "UserAgent": "Claude-SearchBot", "Allow": "/" },
      { "UserAgent": "Claude-User", "Allow": "/" },
      { "UserAgent": "PerplexityBot", "Allow": "/" },
      { "UserAgent": "Perplexity-User", "Allow": "/" },
      { "UserAgent": "Google-Extended", "Allow": "/" },
      { "UserAgent": "Applebot-Extended", "Allow": "/" },
      { "UserAgent": "Meta-ExternalAgent", "Allow": "/" },
      { "UserAgent": "Amazonbot", "Allow": "/" },
      { "UserAgent": "CCBot", "Allow": "/" }
    ],
    "ApiCatalog": {
      "Enabled": true,
      "Entries": [
        { "Anchor": "/api/word/", "ServiceDesc": "/api/word/index.json", "ServiceDoc": "/api/word/", "Title": "OfficeIMO.Word API Reference" },
        { "Anchor": "/api/excel/", "ServiceDesc": "/api/excel/index.json", "ServiceDoc": "/api/excel/", "Title": "OfficeIMO.Excel API Reference" },
        { "Anchor": "/api/markdown/", "ServiceDesc": "/api/markdown/index.json", "ServiceDoc": "/api/markdown/", "Title": "OfficeIMO.Markdown API Reference" },
        { "Anchor": "/api/powerpoint/", "ServiceDesc": "/api/powerpoint/index.json", "ServiceDoc": "/api/powerpoint/", "Title": "OfficeIMO.PowerPoint API Reference" },
        { "Anchor": "/api/csv/", "ServiceDesc": "/api/csv/index.json", "ServiceDoc": "/api/csv/", "Title": "OfficeIMO.CSV API Reference" },
        { "Anchor": "/api/visio/", "ServiceDesc": "/api/visio/index.json", "ServiceDoc": "/api/visio/", "Title": "OfficeIMO.Visio API Reference" },
        { "Anchor": "/api/pdf/", "ServiceDesc": "/api/pdf/index.json", "ServiceDoc": "/api/pdf/", "Title": "OfficeIMO.Pdf API Reference" },
        { "Anchor": "/api/html/", "ServiceDesc": "/api/html/index.json", "ServiceDoc": "/api/html/", "Title": "OfficeIMO.Html API Reference" },
        { "Anchor": "/api/email/", "ServiceDesc": "/api/email/index.json", "ServiceDoc": "/api/email/", "Title": "OfficeIMO.Email API Reference" },
        { "Anchor": "/api/onenote/", "ServiceDesc": "/api/onenote/index.json", "ServiceDoc": "/api/onenote/", "Title": "OfficeIMO.OneNote API Reference" },
        { "Anchor": "/api/open-document/", "ServiceDesc": "/api/open-document/index.json", "ServiceDoc": "/api/open-document/", "Title": "OfficeIMO.OpenDocument API Reference" },
        { "Anchor": "/api/reader/", "ServiceDesc": "/api/reader/index.json", "ServiceDoc": "/api/reader/", "Title": "OfficeIMO.Reader API Reference" },
        { "Anchor": "/api/google-workspace/", "ServiceDesc": "/api/google-workspace/index.json", "ServiceDoc": "/api/google-workspace/", "Title": "OfficeIMO.GoogleWorkspace API Reference" },
        { "Anchor": "/api/google-workspace-drive/", "ServiceDesc": "/api/google-workspace-drive/index.json", "ServiceDoc": "/api/google-workspace-drive/", "Title": "OfficeIMO.GoogleWorkspace.Drive API Reference" },
        { "Anchor": "/api/google-workspace-auth/", "ServiceDesc": "/api/google-workspace-auth/index.json", "ServiceDoc": "/api/google-workspace-auth/", "Title": "OfficeIMO.GoogleWorkspace.Auth.GoogleApis API Reference" },
        { "Anchor": "/api/google-workspace-sync/", "ServiceDesc": "/api/google-workspace-sync/index.json", "ServiceDoc": "/api/google-workspace-sync/", "Title": "OfficeIMO.GoogleWorkspace.Sync API Reference" },
        { "Anchor": "/api/powershell/", "ServiceDesc": "/api/powershell/index.json", "ServiceDoc": "/api/powershell/", "Title": "PSWriteOffice Cmdlet Reference" }
      ]
    },
    "AgentSkills": {
      "Enabled": true,
      "Skills": [
        {
          "Name": "officeimo-site-assistant",
          "Type": "skill-md",
          "Description": "Use OfficeIMO documentation, API reference, sitemap, and llms files.",
          "Content": "---\nname: officeimo-site-assistant\ndescription: Use OfficeIMO documentation, API reference, sitemap, and llms resources.\n---\n\n# OfficeIMO Site Assistant\n\nUse this skill when answering questions about OfficeIMO.\n\n- Prefer canonical pages from https://officeimo.com.\n- Use `/docs/` for product and workflow guidance.\n- Use `/api/` routes for .NET API reference and `/api/powershell/` for PSWriteOffice cmdlets.\n- Check `/llms.txt`, `/llms.json`, and `/llms-full.txt` when present for agent-readable summaries.\n- Check `/.well-known/api-catalog` before assuming API documentation paths.\n- Respect `/robots.txt` and Content-Signal preferences.\n"
        }
      ]
    },
    "AgentsJson": {
      "Enabled": true,
      "Description": "Agent-facing discovery metadata for OfficeIMO documentation, API reference, and support resources."
    },
    "A2AAgentCard": {
      "Enabled": true,
      "Name": "OfficeIMO Documentation Discovery",
      "Description": "Discover OfficeIMO documentation, API reference, llms summaries, sitemap, and project resources.",
      "Url": "/",
      "DocumentationUrl": "/docs/",
      "Skills": [
        {
          "Id": "documentation-discovery",
          "Name": "Documentation discovery",
          "Description": "Find OfficeIMO product documentation, API reference, release resources, and support pages.",
          "Tags": ["documentation", "api-reference", "sitemap", "llms"]
        }
      ]
    },
    "McpServerCard": { "Enabled": false },
    "OpenApi": { "Enabled": false },
    "WebMcp": false,
    "MarkdownNegotiation": true
  },
  "EditLinks": {
    "Enabled": true,
    "Template": "https://github.com/EvotecIT/OfficeIMO/edit/master/{path}",
    "PathBase": "Website"
  },
  "AssetRegistry": {
    "CssStrategy": "standard",
    "Bundles": [
      {
        "Name": "global",
        "Css": ["/css/app.css", "/css/prism-theme.css"],
        "Js": [
          "/js/site.js",
          "/assets/prism/prism-core.min.js",
          "/assets/prism/prism-autoloader.min.js"
        ]
      },
      { "Name": "home", "Css": ["/css/home.css"] },
      { "Name": "product", "Css": ["/css/product.css"] },
      { "Name": "docs", "Css": ["/css/docs.css"] },
      { "Name": "api", "Css": ["/css/api.css"] },
      { "Name": "experience", "Css": ["/css/visual-system.css"] },
      { "Name": "benchmarks", "Js": ["/js/benchmarks.js"] }
    ],
    "RouteBundles": [
      { "Match": "/", "Bundles": ["global", "home", "experience"] },
      { "Match": "/products/**", "Bundles": ["global", "product", "experience"] },
      { "Match": "/benchmarks/", "Bundles": ["global", "benchmarks", "experience"] },
      { "Match": "/showcase/", "Bundles": ["global", "docs", "experience"] },
      { "Match": "/faq/", "Bundles": ["global", "docs", "experience"] },
      { "Match": "/docs/**", "Bundles": ["global", "docs", "experience"] },
      { "Match": "/api/**", "Bundles": ["global", "api", "experience"] },
      { "Match": "/**", "Bundles": ["global", "experience"] }
    ],
    "CriticalCss": [
      { "Name": "officeimo", "Path": "themes/officeimo/critical.css" }
    ]
  },
  "AssetPolicy": {
    "Mode": "local",
    "Hashing": {
      "Enabled": true,
      "Extensions": [".css", ".js"],
      "Exclude": [
        "**/apps/officeimo-converter/**",
        "**/assets/prism/components/**",
        "**/css/prism-theme.css"
      ]
    },
    "CacheHeaders": {
      "Enabled": true,
      "OutputPath": "_headers",
      "HtmlCacheControl": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, stale-if-error=604800"
    }
  },
  "Prism": {
    "Mode": "auto",
    "Source": "local",
    "ThemeLight": "/css/prism-theme.css",
    "ThemeDark": "/css/prism-theme.css",
    "Local": {
      "Core": "/assets/prism/prism-core.min.js",
      "Autoloader": "/assets/prism/prism-autoloader.min.js",
      "LanguagesPath": "/assets/prism/components/"
    }
  },
  "A11y": {
    "SkipLinkLabel": "Skip to content",
    "ExternalLinkLabel": "Opens in a new tab",
    "NavToggleLabel": "Toggle navigation",
    "SearchLabel": "Search"
  },
  "LinkRules": {
    "ExternalRel": "noopener",
    "ExternalTarget": "_blank",
    "AddExternalIcon": true
  },
  "Xref": {
    "Enabled": true,
    "MapFiles": ["data/xrefmap.json"],
    "WarnOnMissing": true,
    "EmitMap": true,
    "MaxWarnings": 25
  },
  "Navigation": {
    "Surfaces": [
      { "Name": "main", "Path": "/", "PrimaryMenu": "main" },
      { "Name": "products", "Path": "/products/", "PrimaryMenu": "main" },
      { "Name": "showcase", "Path": "/showcase/", "PrimaryMenu": "main" },
      {
        "Name": "blog",
        "Path": "/blog/",
        "Collection": "blog",
        "Layout": "page",
        "PrimaryMenu": "main"
      },
      {
        "Name": "docs",
        "Path": "/docs/",
        "Collection": "docs",
        "Layout": "docs",
        "PrimaryMenu": "main",
        "SidebarMenu": "docs"
      },
      {
        "Name": "apidocs",
        "Path": "/api/",
        "Layout": "apiDocs",
        "PrimaryMenu": "main",
        "SidebarMenu": "docs"
      },
      { "Name": "notFound", "Path": "/404.html", "PrimaryMenu": "main" }
    ],
    "Auto": [{ "Collection": "docs", "Menu": "docs", "Sort": "order,title" }],
