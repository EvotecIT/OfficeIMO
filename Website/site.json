{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/main/schemas/powerforge.web.sitespec.schema.json",
  "SchemaVersion": 1,
  "Name": "OfficeIMO",
  "BaseUrl": "https://officeimo.com",
  "DefaultTheme": "officeimo",
  "Features": ["docs", "apiDocs", "blog", "search", "notFound"],
  "TrailingSlash": "always",
  "ContentRoot": "content",
  "ProjectsRoot": "projects",
  "ThemesRoot": "themes",
  "DataRoot": "data",
  "Sources": [
    {
      "Repo": "EvotecIT/PSWriteOffice",
      "Slug": "pswriteoffice",
      "Destination": "./projects/pswriteoffice"
    }
  ],
  "StaticAssets": [{ "Source": "static" }],
  "Collections": [
    {
      "Name": "pages",
      "Input": "content/pages",
      "Output": "/",
      "DefaultLayout": "home",
      "UseToc": false,
      "Include": ["*.md", "**/*.md"]
    },
    {
      "Name": "products",
      "Input": "content/products",
      "Output": "/products",
      "DefaultLayout": "product",
      "UseToc": false,
      "Include": ["*.md", "**/*.md"]
    },
    {
      "Name": "blog",
      "Preset": "blog",
      "Input": "content/blog",
      "Output": "/blog",
      "DefaultLayout": "page",
      "ListLayout": "page",
      "UseToc": false,
      "EditorialCards": {
        "ImageAspect": "16/9",
        "ImageFit": "cover",
        "ImagePosition": "center",
        "GridClass": "imo-editorial-list imo-editorial-list-blog",
        "CardClass": "imo-editorial-card imo-editorial-card-blog"
      },
      "Include": ["*.md", "**/*.md"]
    },
    {
      "Name": "docs",
      "Input": "content/docs",
      "Output": "/docs",
      "DefaultLayout": "docs",
      "UseToc": true,
      "TocFile": "content/docs/toc.json",
      "Include": ["*.md", "**/*.md"]
    }
  ],
  "Taxonomies": [
    {
      "Name": "tags",
      "BasePath": "/tags",
      "ListLayout": "page",
      "TermLayout": "page"
    },
    {
      "Name": "categories",
      "BasePath": "/categories",
      "ListLayout": "page",
      "TermLayout": "page"
    }
  ],
  "Head": {
    "Links": [
      { "Rel": "icon", "Href": "/favicon.svg", "Type": "image/svg+xml" }
    ]
  },
  "Social": {
    "Enabled": true,
    "SiteName": "OfficeIMO",
    "Image": "/images/officeimo-social.png",
    "TwitterCard": "summary_large_image",
    "AutoGenerateCards": true,
    "GeneratedCardsPath": "/assets/social/generated",
    "GeneratedCardWidth": 1200,
    "GeneratedCardHeight": 630,
    "GeneratedCardStyle": "default",
    "GeneratedCardVariant": "standard",
    "GeneratedCardStylesByCollection": {
      "pages": "default",
      "docs": "docs",
      "blog": "editorial",
      "products": "default"
    },
    "GeneratedCardVariantsByCollection": {
      "pages": "hero",
      "docs": "compact",
      "blog": "compact",
      "products": "hero"
    }
  },
  "StructuredData": {
    "Enabled": true,
    "Breadcrumbs": true,
    "OrganizationLegalName": "Evotec Services sp. z o.o.",
    "OrganizationDescription": "Open source .NET libraries for creating, reading, and editing Office documents without Microsoft Office.",
    "OrganizationLogo": "https://officeimo.com/favicon.svg",
    "OrganizationSameAs": [
      "https://github.com/EvotecIT/OfficeIMO",
      "https://github.com/EvotecIT/PSWriteOffice",
      "https://evotec.xyz",
      "https://evo.yt/discord"
    ],
    "OrganizationEmail": "support@evotec.xyz",
    "OrganizationContactUrl": "https://officeimo.com/docs/getting-started/"
  },
  "EditLinks": {
    "Enabled": true,
    "Template": "https://github.com/EvotecIT/OfficeIMO/edit/master/{path}",
    "PathBase": "Website"
  },
  "AssetRegistry": {
    "CssStrategy": "standard",
    "Bundles": [
      {
        "Name": "global",
        "Css": ["/css/app.css", "/css/prism-theme.css"],
        "Js": [
          "/js/site.js",
          "/assets/prism/prism-core.min.js",
          "/assets/prism/prism-autoloader.min.js"
        ]
      },
      {
        "Name": "home",
        "Css": ["/css/app.css", "/css/home.css", "/css/prism-theme.css"],
        "Js": [
          "/js/site.js",
          "/assets/prism/prism-core.min.js",
          "/assets/prism/prism-autoloader.min.js"
        ]
      },
      {
        "Name": "product",
        "Css": ["/css/app.css", "/css/product.css", "/css/prism-theme.css"],
        "Js": [
          "/js/site.js",
          "/assets/prism/prism-core.min.js",
          "/assets/prism/prism-autoloader.min.js"
        ]
      },
      {
        "Name": "docs",
        "Css": ["/css/app.css", "/css/docs.css", "/css/prism-theme.css"],
        "Js": [
          "/js/site.js",
          "/assets/prism/prism-core.min.js",
          "/assets/prism/prism-autoloader.min.js"
        ]
      }
    ],
    "RouteBundles": [
      { "Match": "/", "Bundles": ["global", "home"] },
      { "Match": "/products/**", "Bundles": ["global", "product"] },
      { "Match": "/showcase/", "Bundles": ["global", "docs"] },
      { "Match": "/docs/**", "Bundles": ["global", "docs"] },
      { "Match": "/**", "Bundles": ["global"] }
    ],
    "CriticalCss": [
      { "Name": "officeimo", "Path": "themes/officeimo/critical.css" }
    ]
  },
  "AssetPolicy": {
    "Mode": "local",
    "Hashing": {
      "Enabled": true,
      "Extensions": [".css", ".js"],
      "Exclude": ["**/assets/prism/components/**", "**/css/prism-theme.css"]
    },
    "CacheHeaders": {
      "Enabled": true,
      "OutputPath": "_headers",
      "HtmlCacheControl": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, stale-if-error=604800"
    }
  },
  "Prism": {
    "Mode": "auto",
    "Source": "local",
    "ThemeLight": "/css/prism-theme.css",
    "ThemeDark": "/css/prism-theme.css",
    "Local": {
      "Core": "/assets/prism/prism-core.min.js",
      "Autoloader": "/assets/prism/prism-autoloader.min.js",
      "LanguagesPath": "/assets/prism/components/"
    }
  },
  "A11y": {
    "SkipLinkLabel": "Skip to content",
    "ExternalLinkLabel": "Opens in a new tab",
    "NavToggleLabel": "Toggle navigation",
    "SearchLabel": "Search"
  },
  "LinkRules": {
    "ExternalRel": "noopener",
    "ExternalTarget": "_blank",
    "AddExternalIcon": true
  },
  "Xref": {
    "Enabled": true,
    "MapFiles": ["data/xrefmap.json"],
    "WarnOnMissing": true,
    "EmitMap": true,
    "MaxWarnings": 25
  },
  "Navigation": {
    "Surfaces": [
      { "Name": "main", "Path": "/", "PrimaryMenu": "main" },
      { "Name": "products", "Path": "/products/", "PrimaryMenu": "main" },
      { "Name": "showcase", "Path": "/showcase/", "PrimaryMenu": "main" },
      {
        "Name": "blog",
        "Path": "/blog/",
        "Collection": "blog",
        "Layout": "page",
        "PrimaryMenu": "main"
      },
      {
        "Name": "docs",
        "Path": "/docs/",
        "Collection": "docs",
        "Layout": "docs",
        "PrimaryMenu": "main",
        "SidebarMenu": "docs"
      },
      {
        "Name": "apidocs",
        "Path": "/api/",
        "Layout": "apiDocs",
        "PrimaryMenu": "main",
        "SidebarMenu": "docs"
      },
      { "Name": "notFound", "Path": "/404/", "PrimaryMenu": "main" }
    ],
    "Auto": [{ "Collection": "docs", "Menu": "docs", "Sort": "order,title" }],
    "Menus": [
      {
        "Name": "main",
        "Items": [
          { "Title": "Home", "Url": "/" },
          {
            "Title": "Products",
            "Url": "/products/word/",
            "Sections": [
              {
                "Title": "Core Builders",
                "Items": [
                  {
                    "Title": "OfficeIMO.Word",
                    "Url": "/products/word/",
                    "Description": "Create and edit .docx documents"
                  },
                  {
                    "Title": "OfficeIMO.Excel",
                    "Url": "/products/excel/",
                    "Description": "Read and write .xlsx workbooks"
                  },
                  {
                    "Title": "OfficeIMO.PowerPoint",
                    "Url": "/products/powerpoint/",
                    "Description": "Generate .pptx decks with slides and charts"
                  },
                  {
                    "Title": "OfficeIMO.Markdown",
                    "Url": "/products/markdown/",
                    "Description": "Build, parse, and render Markdown"
                  },
                  {
                    "Title": "OfficeIMO.CSV",
                    "Url": "/products/csv/",
                    "Description": "Typed CSV workflows with schema and streaming"
                  },
                  {
                    "Title": "OfficeIMO.Visio",
                    "Url": "/products/visio/",
                    "Description": "Create .vsdx diagrams with shapes and connectors"
                  }
                ]
              },
              {
                "Title": "Automation and Ingestion",
                "Items": [
                  {
                    "Title": "OfficeIMO.Reader",
                    "Url": "/products/reader/",
                    "Description": "Extract, chunk, and normalize documents for search and AI"
                  },
                  {
                    "Title": "PSWriteOffice",
                    "Url": "/products/pswriteoffice/",
                    "Description": "Automate Office workflows from PowerShell scripts"
                  }
                ]
              }
            ]
          },
          { "Title": "Docs", "Url": "/docs/" },
          { "Title": "Blog", "Url": "/blog/" },
          {
            "Title": "API",
            "Url": "/api/",
            "Sections": [
              {
                "Title": "API Reference",
                "Items": [
                  { "Title": "OfficeIMO.Word API", "Url": "/api/word/" },
                  { "Title": "OfficeIMO.Excel API", "Url": "/api/excel/" },
                  {
                    "Title": "OfficeIMO.PowerPoint API",
                    "Url": "/api/powerpoint/"
                  },
                  {
                    "Title": "OfficeIMO.Markdown API",
                    "Url": "/api/markdown/"
                  },
                  { "Title": "OfficeIMO.CSV API", "Url": "/api/csv/" },
                  { "Title": "OfficeIMO.Visio API", "Url": "/api/visio/" },
                  { "Title": "OfficeIMO.Reader API", "Url": "/api/reader/" },
                  {
                    "Title": "PSWriteOffice Cmdlets",
                    "Url": "/api/powershell/"
                  }
                ]
              }
            ]
          },
          { "Title": "Downloads", "Url": "/downloads/" },
          { "Title": "Pricing", "Url": "/pricing/" }
        ]
      },
      {
        "Name": "footer-products",
        "Items": [
          { "Title": "OfficeIMO.Word", "Url": "/products/word/" },
          { "Title": "OfficeIMO.Excel", "Url": "/products/excel/" },
          { "Title": "OfficeIMO.PowerPoint", "Url": "/products/powerpoint/" },
          { "Title": "OfficeIMO.Markdown", "Url": "/products/markdown/" },
          { "Title": "OfficeIMO.CSV", "Url": "/products/csv/" },
          { "Title": "OfficeIMO.Visio", "Url": "/products/visio/" },
          { "Title": "OfficeIMO.Reader", "Url": "/products/reader/" },
          { "Title": "PSWriteOffice", "Url": "/products/pswriteoffice/" }
        ]
      },
      {
        "Name": "footer-docs",
        "Items": [
          { "Title": "Getting Started", "Url": "/docs/getting-started/" },
          { "Title": "Word Docs", "Url": "/docs/word/" },
          { "Title": "Excel Docs", "Url": "/docs/excel/" },
          { "Title": "PowerPoint Docs", "Url": "/docs/powerpoint/" },
          { "Title": "Markdown Docs", "Url": "/docs/markdown/" },
          { "Title": "CSV Docs", "Url": "/docs/csv/" },
          { "Title": "Visio Docs", "Url": "/docs/visio/" },
          { "Title": "Reader Docs", "Url": "/docs/reader/" },
          { "Title": "PSWriteOffice Docs", "Url": "/docs/pswriteoffice/" }
        ]
      },
      {
        "Name": "footer-resources",
        "Items": [
          { "Title": "FAQ", "Url": "/faq/" },
          { "Title": "Third-Party Dependencies", "Url": "/third-party/" },
          { "Title": "Downloads", "Url": "/downloads/" },
          { "Title": "Changelog", "Url": "/changelog/" },
          { "Title": "Benchmarks", "Url": "/benchmarks/" },
          { "Title": "Comparison", "Url": "/comparison/" },
          { "Title": "Pricing", "Url": "/pricing/" },
          { "Title": "Showcase", "Url": "/showcase/" },
          { "Title": "Blog", "Url": "/blog/" }
        ]
      },
      {
        "Name": "footer-community",
        "Items": [
          {
            "Title": "GitHub (OfficeIMO)",
            "Url": "https://github.com/EvotecIT/OfficeIMO",
            "External": true
          },
          {
            "Title": "GitHub (PSWriteOffice)",
            "Url": "https://github.com/EvotecIT/PSWriteOffice",
            "External": true
          },
          {
            "Title": "NuGet",
            "Url": "https://www.nuget.org/packages?q=OfficeIMO",
            "External": true
          },
          {
            "Title": "PowerShell Gallery",
            "Url": "https://www.powershellgallery.com/packages/PSWriteOffice",
            "External": true
          },
          {
            "Title": "Discord",
            "Url": "https://evo.yt/discord",
            "External": true
          },
          {
            "Title": "Report Issue",
            "Url": "https://github.com/EvotecIT/OfficeIMO/issues",
            "External": true
          }
        ]
      }
    ],
    "Actions": [
      {
        "Title": "GitHub",
        "AriaLabel": "GitHub",
        "Url": "https://github.com/EvotecIT/OfficeIMO",
        "External": true,
        "CssClass": "nav-icon",
        "IconHtml": "<svg viewBox='0 0 24 24' fill='currentColor' aria-hidden='true' focusable='false'><path d='M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z'/></svg>"
      },
      {
        "Title": "Discord",
        "AriaLabel": "Discord",
        "Url": "https://evo.yt/discord",
        "External": true,
        "CssClass": "nav-icon",
        "IconHtml": "<svg viewBox='0 0 24 24' fill='currentColor' aria-hidden='true' focusable='false'><path d='M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z'/></svg>"
      },
      {
        "Title": "Get Started",
        "AriaLabel": "Get Started",
        "Url": "/docs/getting-started/",
        "CssClass": "nav-cta",
        "Text": "Get Started"
      }
    ]
  },
  "LinkCheck": {
    "Enabled": true,
    "IncludeExternal": false
  }
}
