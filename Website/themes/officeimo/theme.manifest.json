{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/main/schemas/powerforge.web.themespec.schema.json",
  "schemaVersion": 2,
  "contractVersion": 2,
  "name": "officeimo",
  "engine": "scriban",
  "layoutsPath": "layouts",
  "partialsPath": "partials",
  "scriptsPath": "scripts",
  "defaultLayout": "home",
  "features": ["docs", "apiDocs", "blog", "search", "notFound"],
  "slots": {
    "header": "header",
    "footer": "footer",
    "api-head": "api-head",
    "api-header": "api-header",
    "api-footer": "api-footer",
    "sidebar": "sidebar",
    "toc": "toc",
    "theme-tokens": "theme-tokens"
  },
  "featureContracts": {
    "apiDocs": {
      "requiredPartials": ["api-header", "api-footer"],
      "cssHrefs": ["/css/app.css", "/css/api.css"],
      "requiredCssSelectors": [
        ".api-layout",
        ".api-sidebar",
        ".api-content",
        ".imo-header--api",
        ".api-nav",
        ".imo-nav__item",
        ".imo-nav__link",
        ".imo-dropdown",
        ".imo-dropdown__group",
        ".imo-dropdown__title",
        ".imo-dropdown__link",
        ".imo-chevron",
        ".api-header__actions",
        ".imo-footer--api",
        ".imo-footer__grid",
        ".imo-footer__grid--api",
        ".imo-footer__brand",
        ".imo-footer__heading",
        ".imo-footer__links",
        ".imo-footer__bottom",
        ".sidebar-toggle",
        ".nav-icon",
        ".nav-cta",
        ".type-item",
        ".type-chip",
        ".filter-button",
        ".quick-card",
        ".namespace-group",
        ".overview-group-toggle",
        ".chevron",
        ".member-card",
        ".member-signature"
      ]
    },
    "docs": {
      "requiredLayouts": ["docs"],
      "requiredPartials": ["header", "footer", "sidebar", "toc", "theme-tokens"]
    },
    "blog": {
      "requiredLayouts": ["page"],
      "requiredSurfaces": ["blog"],
      "cssHrefs": ["/css/app.css"],
      "requiredCssSelectors": [
        ".imo-editorial-list",
        ".imo-editorial-list-blog",
        ".imo-editorial-card",
        ".imo-editorial-card-blog",
        ".pf-editorial-grid--featured",
        ".pf-editorial-card--featured"
      ]
    },
    "notFound": {
      "requiredSurfaces": ["notFound"]
    }
  },
  "tokens": {
    "color": {
      "bg": "#fafbfc",
      "bgDark": "#0f1419",
      "surface": "#ffffff",
      "surfaceDark": "#1a1f2e",
      "ink": "#1e293b",
      "inkDark": "#e2e8f0",
      "muted": "#64748b",
      "primary": "#2563eb",
      "secondary": "#059669",
      "tertiary": "#d97706",
      "border": "rgba(100, 116, 139, 0.15)",
      "headerBg": "rgba(250, 251, 252, 0.95)",
      "headerBgDark": "rgba(15, 20, 25, 0.95)",
      "word": "#2563eb",
      "excel": "#059669",
      "powerpoint": "#dc2626",
      "markdown": "#7c3aed",
      "csv": "#0891b2",
      "visio": "#ea580c",
      "reader": "#4f46e5",
      "powershell": "#d97706"
    },
    "radius": {
      "base": "12px",
      "sm": "8px",
      "lg": "16px",
      "xl": "24px"
    },
    "font": {
      "body": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "display": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "mono": "'Fira Code', 'Cascadia Code', Consolas, monospace"
    },
    "shadow": {
      "sm": "0 1px 2px rgba(0, 0, 0, 0.05)",
      "md": "0 4px 6px -1px rgba(0, 0, 0, 0.07), 0 2px 4px -2px rgba(0, 0, 0, 0.05)",
      "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.04)"
    },
    "layout": {
      "maxWidth": "1200px"
    }
  }
}
