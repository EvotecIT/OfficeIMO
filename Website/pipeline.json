{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/main/schemas/powerforge.web.pipelinespec.schema.json",
  "cache": true,
  "cachePath": "./_temp/pipeline-cache.json",
  "profile": true,
  "profilePath": "./_temp/pipeline-profile.json",
  "steps": [
    {
      "task": "sources-sync",
      "id": "sync-sources",
      "config": "./site.json",
      "lockMode": "verify",
      "lockPath": "./.powerforge/git-sync-lock.json",
      "writeManifest": true
    },
    {
      "task": "dotnet-build",
      "id": "build-word",
      "project": "../OfficeIMO.Word/OfficeIMO.Word.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-excel",
      "project": "../OfficeIMO.Excel/OfficeIMO.Excel.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-powerpoint",
      "project": "../OfficeIMO.PowerPoint/OfficeIMO.PowerPoint.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-markdown",
      "project": "../OfficeIMO.Markdown/OfficeIMO.Markdown.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-csv",
      "project": "../OfficeIMO.CSV/OfficeIMO.CSV.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-visio",
      "project": "../OfficeIMO.Visio/OfficeIMO.Visio.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-reader",
      "project": "../OfficeIMO.Reader/OfficeIMO.Reader.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "release-hub",
      "id": "build-release-hub",
      "dependsOn": ["build-word"],
      "source": "github",
      "repo": "EvotecIT/OfficeIMO",
      "tokenEnv": "GITHUB_TOKEN",
      "out": "./data/release-hub.json",
      "title": "OfficeIMO Releases",
      "maxReleases": 300,
      "pageSize": 100,
      "maxPages": 4,
      "includePrerelease": true,
      "products": [
        { "id": "officeimo.word", "name": "OfficeIMO.Word", "order": 10 },
        { "id": "officeimo.excel", "name": "OfficeIMO.Excel", "order": 20 },
        {
          "id": "officeimo.powerpoint",
          "name": "OfficeIMO.PowerPoint",
          "order": 30
        },
        {
          "id": "officeimo.markdown",
          "name": "OfficeIMO.Markdown",
          "order": 40
        },
        { "id": "officeimo.csv", "name": "OfficeIMO.CSV", "order": 50 },
        { "id": "officeimo.visio", "name": "OfficeIMO.Visio", "order": 60 },
        { "id": "officeimo.reader", "name": "OfficeIMO.Reader", "order": 70 },
        { "id": "pswriteoffice", "name": "PSWriteOffice", "order": 80 },
        {
          "id": "officeimo.word.html",
          "name": "OfficeIMO.Word.Html",
          "order": 90
        },
        {
          "id": "officeimo.word.markdown",
          "name": "OfficeIMO.Word.Markdown",
          "order": 100
        },
        {
          "id": "officeimo.word.pdf",
          "name": "OfficeIMO.Word.Pdf",
          "order": 110
        },
        {
          "id": "officeimo.markdown.html",
          "name": "OfficeIMO.Markdown.Html",
          "order": 120
        },
        {
          "id": "officeimo.markdownrenderer",
          "name": "OfficeIMO.MarkdownRenderer",
          "order": 130
        },
        {
          "id": "officeimo.markdownrenderer.wpf",
          "name": "OfficeIMO.MarkdownRenderer.Wpf",
          "order": 140
        },
        { "id": "officeimo.pdf", "name": "OfficeIMO.Pdf", "order": 150 }
      ],
      "assetRules": [
        {
          "product": "officeimo.word.html",
          "label": "OfficeIMO.Word.Html",
          "match": ["*OfficeIMO.Word.Html*.zip", "*OfficeIMO.Word.Html*.nupkg"]
        },
        {
          "product": "officeimo.word.markdown",
          "label": "OfficeIMO.Word.Markdown",
          "match": [
            "*OfficeIMO.Word.Markdown*.zip",
            "*OfficeIMO.Word.Markdown*.nupkg"
          ]
        },
        {
          "product": "officeimo.word.pdf",
          "label": "OfficeIMO.Word.Pdf",
          "match": ["*OfficeIMO.Word.Pdf*.zip", "*OfficeIMO.Word.Pdf*.nupkg"]
        },
        {
          "product": "officeimo.markdownrenderer.wpf",
          "label": "OfficeIMO.MarkdownRenderer.Wpf",
          "match": [
            "*OfficeIMO.MarkdownRenderer.Wpf*.zip",
            "*OfficeIMO.MarkdownRenderer.Wpf*.nupkg"
          ]
        },
        {
          "product": "officeimo.markdownrenderer",
          "label": "OfficeIMO.MarkdownRenderer",
          "match": [
            "*OfficeIMO.MarkdownRenderer*.zip",
            "*OfficeIMO.MarkdownRenderer*.nupkg"
          ]
        },
        {
          "product": "officeimo.markdown.html",
          "label": "OfficeIMO.Markdown.Html",
          "match": [
            "*OfficeIMO.Markdown.Html*.zip",
            "*OfficeIMO.Markdown.Html*.nupkg"
          ]
        },
        {
          "product": "officeimo.pdf",
          "label": "OfficeIMO.Pdf",
          "match": ["*OfficeIMO.Pdf*.zip", "*OfficeIMO.Pdf*.nupkg"]
        },
        {
          "product": "officeimo.word",
          "label": "OfficeIMO.Word",
          "match": ["*OfficeIMO.Word*.zip", "*OfficeIMO.Word*.nupkg"]
        },
        {
          "product": "officeimo.excel",
          "label": "OfficeIMO.Excel",
          "match": ["*OfficeIMO.Excel*.zip", "*OfficeIMO.Excel*.nupkg"]
        },
        {
          "product": "officeimo.powerpoint",
          "label": "OfficeIMO.PowerPoint",
          "match": [
            "*OfficeIMO.PowerPoint*.zip",
            "*OfficeIMO.PowerPoint*.nupkg"
          ]
        },
        {
          "product": "officeimo.markdown",
          "label": "OfficeIMO.Markdown",
          "match": ["*OfficeIMO.Markdown*.zip", "*OfficeIMO.Markdown*.nupkg"]
        },
        {
          "product": "officeimo.csv",
          "label": "OfficeIMO.CSV",
          "match": ["*OfficeIMO.CSV*.zip", "*OfficeIMO.CSV*.nupkg"]
        },
        {
          "product": "officeimo.visio",
          "label": "OfficeIMO.Visio",
          "match": ["*OfficeIMO.Visio*.zip", "*OfficeIMO.Visio*.nupkg"]
        },
        {
          "product": "officeimo.reader",
          "label": "OfficeIMO.Reader",
          "match": ["*OfficeIMO.Reader*.zip", "*OfficeIMO.Reader*.nupkg"]
        },
        {
          "product": "pswriteoffice",
          "label": "PSWriteOffice",
          "match": ["*PSWriteOffice*.zip", "*PSWriteOffice*.nupkg"]
        }
      ]
    },
    {
      "task": "ecosystem-stats",
      "id": "build-ecosystem-stats",
      "skipModes": ["dev"],
      "out": "./data/ecosystem/stats.json",
      "publishPath": "./static/data/ecosystem/stats.json",
      "summaryPath": "./Build/sync-ecosystem-stats-last-run.json",
      "title": "OfficeIMO Package Telemetry",
      "nugetOwner": "Evotec",
      "timeoutSeconds": 60,
      "preserveOnWarnings": true
    },
    {
      "task": "build",
      "id": "build-site",
      "dependsOn": [
        "sync-sources",
        "build-word",
        "build-excel",
        "build-powerpoint",
        "build-markdown",
        "build-csv",
        "build-visio",
        "build-reader",
        "build-release-hub",
        "build-ecosystem-stats"
      ],
      "config": "./site.json",
      "out": "./_site",
      "clean": true
    },
    {
      "task": "exec",
      "id": "sync-pswriteoffice-apidocs",
      "dependsOn": ["sync-sources"],
      "command": "pwsh",
      "argsList": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "./scripts/Sync-PSWriteOfficeApiDocs.ps1",
        "-SiteRoot",
        "."
      ],
      "workingDirectory": "."
    },
    {
      "task": "verify",
      "id": "verify-site",
      "dependsOn": "build-site",
      "config": "./site.json"
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-word",
      "dependsOn": ["build-word", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Word/bin/Release/net8.0/OfficeIMO.Word.xml",
      "assembly": "../OfficeIMO.Word/bin/Release/net8.0/OfficeIMO.Word.dll",
      "out": "./_site/api/word",
      "title": "OfficeIMO.Word API Reference",
      "baseUrl": "/api/word",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Word",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-excel",
      "dependsOn": ["build-excel", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Excel/bin/Release/net8.0/OfficeIMO.Excel.xml",
      "assembly": "../OfficeIMO.Excel/bin/Release/net8.0/OfficeIMO.Excel.dll",
      "out": "./_site/api/excel",
      "title": "OfficeIMO.Excel API Reference",
      "baseUrl": "/api/excel",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Excel",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-markdown",
      "dependsOn": ["build-markdown", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Markdown/bin/Release/net8.0/OfficeIMO.Markdown.xml",
      "assembly": "../OfficeIMO.Markdown/bin/Release/net8.0/OfficeIMO.Markdown.dll",
      "out": "./_site/api/markdown",
      "title": "OfficeIMO.Markdown API Reference",
      "baseUrl": "/api/markdown",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Markdown",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-powerpoint",
      "dependsOn": ["build-powerpoint", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.PowerPoint/bin/Release/net8.0/OfficeIMO.PowerPoint.xml",
      "assembly": "../OfficeIMO.PowerPoint/bin/Release/net8.0/OfficeIMO.PowerPoint.dll",
      "out": "./_site/api/powerpoint",
      "title": "OfficeIMO.PowerPoint API Reference",
      "baseUrl": "/api/powerpoint",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.PowerPoint",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-csv",
      "dependsOn": ["build-csv", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.CSV/bin/Release/net8.0/OfficeIMO.CSV.xml",
      "assembly": "../OfficeIMO.CSV/bin/Release/net8.0/OfficeIMO.CSV.dll",
      "out": "./_site/api/csv",
      "title": "OfficeIMO.CSV API Reference",
      "baseUrl": "/api/csv",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.CSV",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-visio",
      "dependsOn": ["build-visio", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Visio/bin/Release/net8.0/OfficeIMO.Visio.xml",
      "assembly": "../OfficeIMO.Visio/bin/Release/net8.0/OfficeIMO.Visio.dll",
      "out": "./_site/api/visio",
      "title": "OfficeIMO.Visio API Reference",
      "baseUrl": "/api/visio",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Visio",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-reader",
      "dependsOn": ["build-reader", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Reader/bin/Release/net8.0/OfficeIMO.Reader.xml",
      "assembly": "../OfficeIMO.Reader/bin/Release/net8.0/OfficeIMO.Reader.dll",
      "out": "./_site/api/reader",
      "title": "OfficeIMO.Reader API Reference",
      "baseUrl": "/api/reader",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Reader",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-powershell",
      "dependsOn": ["build-site", "sync-pswriteoffice-apidocs"],
      "config": "./site.json",
      "type": "PowerShell",
      "helpPath": "./data/apidocs/powershell/PSWriteOffice-Help.xml",
      "psManifestPath": "./data/apidocs/powershell/PSWriteOffice.psd1",
      "psCommandMetadataPath": "./data/apidocs/powershell/command-metadata.json",
      "psExamplesPath": "./data/apidocs/powershell/examples",
      "out": "./_site/api/powershell",
      "title": "PSWriteOffice Cmdlet Reference",
      "baseUrl": "/api/powershell",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "bodyClass": "pf-api-docs pf-api-docs--powershell",
      "docsHome": "/products/pswriteoffice/",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "injectCriticalCss": true
    },
    {
      "task": "xref-merge",
      "id": "merge-xref",
      "dependsOn": [
        "build-apidocs-word",
        "build-apidocs-excel",
        "build-apidocs-markdown",
        "build-apidocs-powerpoint",
        "build-apidocs-csv",
        "build-apidocs-visio",
        "build-apidocs-reader",
        "build-apidocs-powershell"
      ],
      "out": "./data/xrefmap.json",
      "mapFiles": [
        "./_site/api/word/xrefmap.json",
        "./_site/api/excel/xrefmap.json",
        "./_site/api/markdown/xrefmap.json",
        "./_site/api/powerpoint/xrefmap.json",
        "./_site/api/csv/xrefmap.json",
        "./_site/api/visio/xrefmap.json",
        "./_site/api/reader/xrefmap.json",
        "./_site/api/powershell/xrefmap.json"
      ],
      "preferLast": true,
      "maxReferences": 90000,
      "maxDuplicates": 100
    },
    {
      "task": "build",
      "id": "build-site-xref-refresh",
      "dependsOn": "merge-xref",
      "config": "./site.json",
      "out": "./_site",
      "clean": false
    },
    {
      "task": "verify",
      "id": "verify-ci",
      "dependsOn": "build-site-xref-refresh",
      "modes": ["ci"],
      "config": "./site.json",
      "baseline": "./.powerforge/verify-baseline.json",
      "failOnNewWarnings": true,
      "failOnNavLint": true,
      "failOnThemeContract": true
    },
    {
      "task": "llms",
      "id": "build-llms",
      "dependsOn": "verify-ci",
      "siteRoot": "./_site",
      "apiIndex": "./_site/api/word/index.json",
      "apiBase": "/api",
      "name": "OfficeIMO",
      "license": "MIT",
      "targets": ".NET 8+, .NET 10+, .NET Standard 2.0, .NET Framework 4.7.2"
    },
    {
      "task": "sitemap",
      "id": "build-sitemap",
      "dependsOn": "build-llms",
      "siteRoot": "./_site",
      "baseUrl": "https://officeimo.com",
      "apiSitemap": "./_site/api/word/sitemap.xml",
      "includeNoIndexHtml": false,
      "noDefaultExclude": false,
      "excludePatterns": [
        "**/api-fragments/**",
        "**/*.scripts.html",
        "**/*.head.html"
      ],
      "includeGeneratedHtmlRouteInXml": false,
      "json": true,
      "jsonOut": "./_site/sitemap/index.json",
      "html": true,
      "htmlOutput": "./_site/sitemap/index.html",
      "htmlTemplate": "./themes/officeimo/templates/sitemap.html",
      "htmlTitle": "OfficeIMO Sitemap"
    },
    {
      "task": "optimize",
      "id": "optimize-site",
      "dependsOn": "build-sitemap",
      "skipModes": ["dev"],
      "siteRoot": "./_site",
      "config": "./site.json",
      "criticalCss": "./themes/officeimo/critical.css",
      "minifyHtml": true,
      "minifyCss": true,
      "minifyJs": true,
      "optimizeImages": true,
      "hashAssets": true,
      "hashExtensions": [".css", ".js"],
      "hashExclude": [
        "**/assets/prism/components/**",
        "**/css/prism-theme.css"
      ],
      "cacheHeaders": true,
      "cacheHeadersOut": "_headers"
    },
    {
      "task": "audit",
      "id": "audit-ci",
      "dependsOn": "optimize-site",
      "modes": ["ci"],
      "config": "./site.json",
      "siteRoot": "./_site",
      "baseline": "./.powerforge/audit-baseline.json",
      "failOnNewIssues": true,
      "navSelector": "header nav",
      "navCanonicalPath": "index.html",
      "navCanonicalRequired": true,
      "requiredRoutes": "/,/docs/,/404.html,/api/,/api/powershell/,/api/powerpoint/,/api/csv/,/api/visio/,/api/reader/,/blog/,/showcase/,/products/word/"
    },
    {
      "task": "doctor",
      "id": "doctor-site",
      "dependsOn": "optimize-site",
      "skipModes": ["dev", "ci"],
      "config": "./site.json",
      "siteRoot": "./_site",
      "noBuild": true,
      "noVerify": true,
      "navSelector": "header nav",
      "navCanonicalPath": "index.html",
      "navCanonicalRequired": true,
      "requiredRoutes": "/,/docs/,/404.html,/api/,/api/powershell/,/api/powerpoint/,/api/csv/,/api/visio/,/api/reader/,/blog/,/showcase/,/products/word/"
    }
  ]
}
