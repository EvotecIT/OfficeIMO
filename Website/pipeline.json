{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/main/schemas/powerforge.web.pipelinespec.schema.json",
  "cache": true,
  "cachePath": "./_temp/pipeline-cache.json",
  "profile": true,
  "profilePath": "./_temp/pipeline-profile.json",
  "steps": [
    {
      "task": "sources-sync",
      "id": "sync-sources",
      "config": "./site.json",
      "lockMode": "verify",
      "lockPath": "./.powerforge/git-sync-lock.json",
      "writeManifest": true
    },
    {
      "task": "exec",
      "id": "sync-pswriteoffice-content",
      "dependsOn": ["sync-sources"],
      "command": "pwsh",
      "argsList": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "./scripts/Sync-PSWriteOfficeApiDocs.ps1",
        "-SiteRoot",
        "."
      ],
      "workingDirectory": "."
    },
    {
      "task": "exec",
      "id": "build-documentation-catalog",
      "dependsOn": ["sync-pswriteoffice-content"],
      "command": "pwsh",
      "argsList": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "./scripts/Build-DocumentationCatalog.ps1"
      ],
      "workingDirectory": "."
    },
    {
      "task": "exec",
      "id": "build-aot-project-matrix",
      "dependsOn": ["build-documentation-catalog"],
      "command": "pwsh",
      "argsList": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "../Build/Test-AotProjectCoverage.ps1",
        "-JsonOutputPath",
        "./static/data/aot-compatibility.json"
      ],
      "workingDirectory": "."
    },
    {
      "task": "exec",
      "id": "test-documentation-contracts",
      "dependsOn": ["build-aot-project-matrix"],
      "command": "pwsh",
      "argsList": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "./scripts/Test-DocumentationContracts.ps1"
      ],
      "workingDirectory": "."
    },
    {
      "task": "dotnet-build",
      "id": "build-word",
      "project": "../OfficeIMO.Word/OfficeIMO.Word.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-excel",
      "project": "../OfficeIMO.Excel/OfficeIMO.Excel.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-excel-pdf",
      "project": "../OfficeIMO.Excel.Pdf/OfficeIMO.Excel.Pdf.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-powerpoint",
      "project": "../OfficeIMO.PowerPoint/OfficeIMO.PowerPoint.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-markdown",
      "project": "../OfficeIMO.Markdown/OfficeIMO.Markdown.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-csv",
      "project": "../OfficeIMO.CSV/OfficeIMO.CSV.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-visio",
      "project": "../OfficeIMO.Visio/OfficeIMO.Visio.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-reader",
      "project": "../OfficeIMO.Reader.Core/OfficeIMO.Reader.Core.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-pdf",
      "project": "../OfficeIMO.Pdf/OfficeIMO.Pdf.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-word-pdf",
      "project": "../OfficeIMO.Word.Pdf/OfficeIMO.Word.Pdf.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-html",
      "project": "../OfficeIMO.Html/OfficeIMO.Html.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-email",
      "project": "../OfficeIMO.Email/OfficeIMO.Email.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-onenote",
      "project": "../OfficeIMO.OneNote/OfficeIMO.OneNote.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-open-document",
      "project": "../OfficeIMO.OpenDocument/OfficeIMO.OpenDocument.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-google-workspace",
      "project": "../OfficeIMO.GoogleWorkspace/OfficeIMO.GoogleWorkspace.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-google-workspace-drive",
      "project": "../OfficeIMO.GoogleWorkspace.Drive/OfficeIMO.GoogleWorkspace.Drive.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-google-workspace-auth",
      "project": "../OfficeIMO.GoogleWorkspace.Auth.GoogleApis/OfficeIMO.GoogleWorkspace.Auth.GoogleApis.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-google-workspace-sync",
      "project": "../OfficeIMO.GoogleWorkspace.Sync/OfficeIMO.GoogleWorkspace.Sync.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "release-hub",
      "id": "build-release-hub",
      "dependsOn": ["build-word"],
      "source": "github",
      "repo": "EvotecIT/OfficeIMO",
      "tokenEnv": "GITHUB_TOKEN",
      "out": "./data/release-hub.json",
      "title": "OfficeIMO Releases",
      "maxReleases": 300,
      "pageSize": 100,
      "maxPages": 4,
      "includePrerelease": true,
      "products": [
        { "id": "officeimo.word", "name": "OfficeIMO.Word", "order": 10 },
        { "id": "officeimo.excel", "name": "OfficeIMO.Excel", "order": 20 },
        {
          "id": "officeimo.excel.pdf",
          "name": "OfficeIMO.Excel.Pdf",
          "order": 25
        },
        {
          "id": "officeimo.powerpoint",
          "name": "OfficeIMO.PowerPoint",
          "order": 30
        },
        {
          "id": "officeimo.markdown",
          "name": "OfficeIMO.Markdown",
          "order": 40
        },
        { "id": "officeimo.csv", "name": "OfficeIMO.CSV", "order": 50 },
        { "id": "officeimo.visio", "name": "OfficeIMO.Visio", "order": 60 },
        { "id": "officeimo.reader", "name": "OfficeIMO.Reader packages", "order": 70 },
        { "id": "pswriteoffice", "name": "PSWriteOffice", "order": 80 },
        { "id": "officeimo.googleworkspace", "name": "OfficeIMO.GoogleWorkspace", "order": 81 },
        { "id": "officeimo.googleworkspace.drive", "name": "OfficeIMO.GoogleWorkspace.Drive", "order": 82 },
        { "id": "officeimo.googleworkspace.auth.googleapis", "name": "OfficeIMO.GoogleWorkspace.Auth.GoogleApis", "order": 83 },
        { "id": "officeimo.googleworkspace.sync", "name": "OfficeIMO.GoogleWorkspace.Sync", "order": 84 },
        { "id": "officeimo.word.googledocs", "name": "OfficeIMO.Word.GoogleDocs", "order": 85 },
        { "id": "officeimo.excel.googlesheets", "name": "OfficeIMO.Excel.GoogleSheets", "order": 86 },
        { "id": "officeimo.powerpoint.googleslides", "name": "OfficeIMO.PowerPoint.GoogleSlides", "order": 87 },
        {
          "id": "officeimo.word.html",
          "name": "OfficeIMO.Word.Html",
          "order": 90
        },
        {
          "id": "officeimo.word.markdown",
          "name": "OfficeIMO.Word.Markdown",
          "order": 100
        },
        {
          "id": "officeimo.word.pdf",
          "name": "OfficeIMO.Word.Pdf",
          "order": 110
        },
        {
          "id": "officeimo.markdown.html",
          "name": "OfficeIMO.Markdown.Html",
          "order": 120
        },
        {
          "id": "officeimo.markdownrenderer",
          "name": "OfficeIMO.MarkdownRenderer",
          "order": 130
        },
        {
          "id": "officeimo.markdownrenderer.wpf",
          "name": "OfficeIMO.MarkdownRenderer.Wpf",
          "order": 140
        },
        { "id": "officeimo.pdf", "name": "OfficeIMO.Pdf", "order": 150 }
      ],
      "assetRules": [
        {
          "product": "officeimo.googleworkspace.auth.googleapis",
          "label": "OfficeIMO.GoogleWorkspace.Auth.GoogleApis",
          "match": ["*OfficeIMO.GoogleWorkspace.Auth.GoogleApis*.nupkg"]
        },
        {
          "product": "officeimo.googleworkspace.drive",
          "label": "OfficeIMO.GoogleWorkspace.Drive",
          "match": ["*OfficeIMO.GoogleWorkspace.Drive*.nupkg"]
        },
        {
          "product": "officeimo.googleworkspace.sync",
          "label": "OfficeIMO.GoogleWorkspace.Sync",
          "match": ["*OfficeIMO.GoogleWorkspace.Sync*.nupkg"]
        },
        {
          "product": "officeimo.word.googledocs",
          "label": "OfficeIMO.Word.GoogleDocs",
          "match": ["*OfficeIMO.Word.GoogleDocs*.nupkg"]
        },
        {
          "product": "officeimo.excel.googlesheets",
          "label": "OfficeIMO.Excel.GoogleSheets",
          "match": ["*OfficeIMO.Excel.GoogleSheets*.nupkg"]
        },
        {
          "product": "officeimo.powerpoint.googleslides",
          "label": "OfficeIMO.PowerPoint.GoogleSlides",
          "match": ["*OfficeIMO.PowerPoint.GoogleSlides*.nupkg"]
        },
        {
          "product": "officeimo.googleworkspace",
          "label": "OfficeIMO.GoogleWorkspace",
          "match": ["*OfficeIMO.GoogleWorkspace*.nupkg"]
        },
        {
          "product": "officeimo.word.html",
          "label": "OfficeIMO.Word.Html",
          "match": ["*OfficeIMO.Word.Html*.zip", "*OfficeIMO.Word.Html*.nupkg"]
        },
        {
          "product": "officeimo.word.markdown",
          "label": "OfficeIMO.Word.Markdown",
          "match": [
            "*OfficeIMO.Word.Markdown*.zip",
            "*OfficeIMO.Word.Markdown*.nupkg"
          ]
        },
        {
          "product": "officeimo.word.pdf",
          "label": "OfficeIMO.Word.Pdf",
          "match": ["*OfficeIMO.Word.Pdf*.zip", "*OfficeIMO.Word.Pdf*.nupkg"]
        },
        {
          "product": "officeimo.excel.pdf",
          "label": "OfficeIMO.Excel.Pdf",
          "match": ["*OfficeIMO.Excel.Pdf*.zip", "*OfficeIMO.Excel.Pdf*.nupkg"]
        },
        {
          "product": "officeimo.markdownrenderer.wpf",
          "label": "OfficeIMO.MarkdownRenderer.Wpf",
          "match": [
            "*OfficeIMO.MarkdownRenderer.Wpf*.zip",
            "*OfficeIMO.MarkdownRenderer.Wpf*.nupkg"
          ]
        },
        {
          "product": "officeimo.markdownrenderer",
          "label": "OfficeIMO.MarkdownRenderer",
          "match": [
            "*OfficeIMO.MarkdownRenderer*.zip",
            "*OfficeIMO.MarkdownRenderer*.nupkg"
          ]
        },
        {
          "product": "officeimo.markdown.html",
          "label": "OfficeIMO.Markdown.Html",
          "match": [
            "*OfficeIMO.Markdown.Html*.zip",
            "*OfficeIMO.Markdown.Html*.nupkg"
          ]
        },
        {
          "product": "officeimo.pdf",
          "label": "OfficeIMO.Pdf",
          "match": ["*OfficeIMO.Pdf*.zip", "*OfficeIMO.Pdf*.nupkg"]
        },
        {
          "product": "officeimo.word",
          "label": "OfficeIMO.Word",
          "match": ["*OfficeIMO.Word*.zip", "*OfficeIMO.Word*.nupkg"]
        },
        {
          "product": "officeimo.excel",
          "label": "OfficeIMO.Excel",
          "match": ["*OfficeIMO.Excel*.zip", "*OfficeIMO.Excel*.nupkg"]
        },
        {
          "product": "officeimo.powerpoint",
          "label": "OfficeIMO.PowerPoint",
          "match": [
            "*OfficeIMO.PowerPoint*.zip",
            "*OfficeIMO.PowerPoint*.nupkg"
          ]
        },
        {
          "product": "officeimo.markdown",
          "label": "OfficeIMO.Markdown",
          "match": ["*OfficeIMO.Markdown*.zip", "*OfficeIMO.Markdown*.nupkg"]
        },
        {
          "product": "officeimo.csv",
          "label": "OfficeIMO.CSV",
          "match": ["*OfficeIMO.CSV*.zip", "*OfficeIMO.CSV*.nupkg"]
        },
        {
          "product": "officeimo.visio",
          "label": "OfficeIMO.Visio",
          "match": ["*OfficeIMO.Visio*.zip", "*OfficeIMO.Visio*.nupkg"]
        },
        {
          "product": "officeimo.reader",
          "label": "OfficeIMO.Reader packages",
          "match": ["*OfficeIMO.Reader*.zip", "*OfficeIMO.Reader*.nupkg"]
        },
        {
          "product": "pswriteoffice",
          "label": "PSWriteOffice",
          "match": ["*PSWriteOffice*.zip", "*PSWriteOffice*.nupkg"]
        }
      ]
    },
    {
      "task": "ecosystem-stats",
      "id": "build-ecosystem-stats",
      "skipModes": ["dev"],
      "out": "./data/ecosystem/stats.json",
      "publishPath": "./static/data/ecosystem/stats.json",
      "summaryPath": "./Build/sync-ecosystem-stats-last-run.json",
      "title": "OfficeIMO Package Telemetry",
      "nugetOwner": "Evotec",
      "timeoutSeconds": 60,
      "preserveOnWarnings": true
    },
    {
      "task": "exec",
      "id": "generate-excel-benchmark-data",
      "dependsOn": ["build-excel"],
      "command": "pwsh",
      "argsList": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "./Build/Generate-ExcelBenchmarkWebsiteData.ps1",
        "-PackageProfilePath",
        ".\\Docs\\benchmarks\\officeimo.excel.package-profile-blog-2023-20-string-columns-10k-current.json;.\\Docs\\benchmarks\\officeimo.excel.package-profile-blog-2023-20-string-columns-300k-current.json",
        "-RunMode",
        "quick"
      ],
      "workingDirectory": ".."
    },
    {
      "task": "exec",
      "id": "generate-benchmark-overview",
      "dependsOn": ["generate-excel-benchmark-data"],
      "command": "pwsh",
      "argsList": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "./Build/Generate-BenchmarkWebsiteOverview.ps1"
      ],
      "workingDirectory": ".."
    },
    {
      "task": "build",
      "id": "build-site",
      "dependsOn": [
        "sync-sources",
        "test-documentation-contracts",
        "build-word",
        "build-excel",
        "build-excel-pdf",
        "build-powerpoint",
        "build-markdown",
        "build-csv",
        "build-visio",
        "build-reader",
        "build-pdf",
        "build-word-pdf",
        "build-html",
        "build-email",
        "build-onenote",
        "build-open-document",
        "build-google-workspace",
        "build-google-workspace-drive",
        "build-google-workspace-auth",
        "build-google-workspace-sync",
        "build-release-hub",
        "build-ecosystem-stats",
        "generate-benchmark-overview"
      ],
      "config": "./site.json",
      "out": "./_site",
      "clean": true
    },
    {
      "task": "overlay",
      "id": "deploy-theme-css",
      "dependsOn": "build-site",
      "source": "./themes/officeimo/assets",
      "destination": "./_site/css",
      "clean": false,
      "include": "**/*, *"
    },
    {
      "task": "exec",
      "id": "verify-excel-benchmark-page",
      "dependsOn": ["build-site"],
      "command": "pwsh",
      "argsList": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "./scripts/Test-BenchmarkPage.ps1",
        "-SiteRoot",
        "./_site"
      ],
      "workingDirectory": "."
    },
    {
      "task": "verify",
      "id": "verify-site",
      "dependsOn": ["deploy-theme-css", "verify-excel-benchmark-page"],
      "config": "./site.json"
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-word",
      "dependsOn": ["build-word", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Word/bin/Release/net8.0/OfficeIMO.Word.xml",
      "assembly": "../OfficeIMO.Word/bin/Release/net8.0/OfficeIMO.Word.dll",
      "out": "./_site/api/word",
      "title": "OfficeIMO.Word API Reference",
      "baseUrl": "/api/word",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css,/css/visual-system.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Word",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-excel",
      "dependsOn": ["build-excel", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Excel/bin/Release/net8.0/OfficeIMO.Excel.xml",
      "assembly": "../OfficeIMO.Excel/bin/Release/net8.0/OfficeIMO.Excel.dll",
      "out": "./_site/api/excel",
      "title": "OfficeIMO.Excel API Reference",
      "baseUrl": "/api/excel",
      "format": "both",
      "legacyAliasMode": "omit",
      "suppressWarnings": ["PFWEB.APIDOCS.MEMBER.SIGNATURES"],
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css,/css/visual-system.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Excel",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-markdown",
      "dependsOn": ["build-markdown", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Markdown/bin/Release/net8.0/OfficeIMO.Markdown.xml",
      "assembly": "../OfficeIMO.Markdown/bin/Release/net8.0/OfficeIMO.Markdown.dll",
      "out": "./_site/api/markdown",
      "title": "OfficeIMO.Markdown API Reference",
      "baseUrl": "/api/markdown",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css,/css/visual-system.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Markdown",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-powerpoint",
      "dependsOn": ["build-powerpoint", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.PowerPoint/bin/Release/net8.0/OfficeIMO.PowerPoint.xml",
      "assembly": "../OfficeIMO.PowerPoint/bin/Release/net8.0/OfficeIMO.PowerPoint.dll",
      "out": "./_site/api/powerpoint",
      "title": "OfficeIMO.PowerPoint API Reference",
      "baseUrl": "/api/powerpoint",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css,/css/visual-system.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.PowerPoint",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-csv",
      "dependsOn": ["build-csv", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.CSV/bin/Release/net8.0/OfficeIMO.CSV.xml",
      "assembly": "../OfficeIMO.CSV/bin/Release/net8.0/OfficeIMO.CSV.dll",
      "out": "./_site/api/csv",
      "title": "OfficeIMO.CSV API Reference",
      "baseUrl": "/api/csv",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css,/css/visual-system.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.CSV",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-visio",
      "dependsOn": ["build-visio", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Visio/bin/Release/net8.0/OfficeIMO.Visio.xml",
      "assembly": "../OfficeIMO.Visio/bin/Release/net8.0/OfficeIMO.Visio.dll",
      "out": "./_site/api/visio",
      "title": "OfficeIMO.Visio API Reference",
      "baseUrl": "/api/visio",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css,/css/visual-system.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Visio",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-pdf",
      "dependsOn": ["build-pdf", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Pdf/bin/Release/net8.0/OfficeIMO.Pdf.xml",
      "assembly": "../OfficeIMO.Pdf/bin/Release/net8.0/OfficeIMO.Pdf.dll",
      "out": "./_site/api/pdf",
      "title": "OfficeIMO.Pdf API Reference",
      "baseUrl": "/api/pdf",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css,/css/visual-system.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Pdf",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-html",
      "dependsOn": ["build-html", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Html/bin/Release/net8.0/OfficeIMO.Html.xml",
      "assembly": "../OfficeIMO.Html/bin/Release/net8.0/OfficeIMO.Html.dll",
      "out": "./_site/api/html",
      "title": "OfficeIMO.Html API Reference",
      "baseUrl": "/api/html",
