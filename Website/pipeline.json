{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/main/schemas/powerforge.web.pipelinespec.schema.json",
  "cache": true,
  "cachePath": "./_temp/pipeline-cache.json",
  "profile": true,
  "profilePath": "./_temp/pipeline-profile.json",
  "steps": [
    {
      "task": "dotnet-build",
      "id": "build-word",
      "project": "../OfficeIMO.Word/OfficeIMO.Word.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-excel",
      "project": "../OfficeIMO.Excel/OfficeIMO.Excel.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-powerpoint",
      "project": "../OfficeIMO.PowerPoint/OfficeIMO.PowerPoint.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-markdown",
      "project": "../OfficeIMO.Markdown/OfficeIMO.Markdown.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-csv",
      "project": "../OfficeIMO.CSV/OfficeIMO.CSV.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-visio",
      "project": "../OfficeIMO.Visio/OfficeIMO.Visio.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-reader",
      "project": "../OfficeIMO.Reader/OfficeIMO.Reader.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "release-hub",
      "id": "build-release-hub",
      "dependsOn": ["build-word"],
      "source": "github",
      "repo": "EvotecIT/OfficeIMO",
      "tokenEnv": "GITHUB_TOKEN",
      "out": "./data/release-hub.json",
      "title": "OfficeIMO Releases",
      "maxReleases": 300,
      "pageSize": 100,
      "maxPages": 4,
      "includePrerelease": true,
      "products": [
        { "id": "officeimo.word", "name": "OfficeIMO.Word", "order": 10 },
        { "id": "officeimo.excel", "name": "OfficeIMO.Excel", "order": 20 },
        { "id": "officeimo.powerpoint", "name": "OfficeIMO.PowerPoint", "order": 30 },
        { "id": "officeimo.markdown", "name": "OfficeIMO.Markdown", "order": 40 },
        { "id": "officeimo.csv", "name": "OfficeIMO.CSV", "order": 50 },
        { "id": "officeimo.visio", "name": "OfficeIMO.Visio", "order": 60 },
        { "id": "officeimo.reader", "name": "OfficeIMO.Reader", "order": 70 },
        { "id": "pswriteoffice", "name": "PSWriteOffice", "order": 80 }
      ],
      "assetRules": [
        { "product": "officeimo.word", "label": "OfficeIMO.Word", "match": ["*OfficeIMO.Word*.nupkg"] },
        { "product": "officeimo.excel", "label": "OfficeIMO.Excel", "match": ["*OfficeIMO.Excel*.nupkg"] },
        { "product": "officeimo.powerpoint", "label": "OfficeIMO.PowerPoint", "match": ["*OfficeIMO.PowerPoint*.nupkg"] },
        { "product": "officeimo.markdown", "label": "OfficeIMO.Markdown", "match": ["*OfficeIMO.Markdown*.nupkg"] },
        { "product": "officeimo.csv", "label": "OfficeIMO.CSV", "match": ["*OfficeIMO.CSV*.nupkg"] },
        { "product": "officeimo.visio", "label": "OfficeIMO.Visio", "match": ["*OfficeIMO.Visio*.nupkg"] },
        { "product": "officeimo.reader", "label": "OfficeIMO.Reader", "match": ["*OfficeIMO.Reader*.nupkg"] },
        { "product": "pswriteoffice", "label": "PSWriteOffice", "match": ["*PSWriteOffice*.zip", "*PSWriteOffice*.nupkg"] }
      ]
    },
    {
      "task": "build",
      "id": "build-site",
      "dependsOn": ["build-word", "build-excel", "build-powerpoint", "build-markdown", "build-csv", "build-visio", "build-reader", "build-release-hub"],
      "config": "./site.json",
      "out": "./_site",
      "clean": true
    },
    {
      "task": "verify",
      "id": "verify-site",
      "dependsOn": "build-site",
      "config": "./site.json"
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-word",
      "dependsOn": ["build-word", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Word/bin/Release/net8.0/OfficeIMO.Word.xml",
      "assembly": "../OfficeIMO.Word/bin/Release/net8.0/OfficeIMO.Word.dll",
      "out": "./_site/api/word",
      "title": "OfficeIMO.Word API Reference",
      "baseUrl": "/api/word",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Word",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-excel",
      "dependsOn": ["build-excel", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Excel/bin/Release/net8.0/OfficeIMO.Excel.xml",
      "assembly": "../OfficeIMO.Excel/bin/Release/net8.0/OfficeIMO.Excel.dll",
      "out": "./_site/api/excel",
      "title": "OfficeIMO.Excel API Reference",
      "baseUrl": "/api/excel",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Excel",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-markdown",
      "dependsOn": ["build-markdown", "build-site"],
      "config": "./site.json",
      "xml": "../OfficeIMO.Markdown/bin/Release/net8.0/OfficeIMO.Markdown.xml",
      "assembly": "../OfficeIMO.Markdown/bin/Release/net8.0/OfficeIMO.Markdown.dll",
      "out": "./_site/api/markdown",
      "title": "OfficeIMO.Markdown API Reference",
      "baseUrl": "/api/markdown",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/OfficeIMO/blob/master/{path}#L{line}",
      "includeNamespace": "OfficeIMO.Markdown",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-powershell",
      "dependsOn": "build-site",
      "config": "./site.json",
      "type": "PowerShell",
      "helpPath": "./data/apidocs/powershell/PSWriteOffice-Help.xml",
      "psExamplesPath": "./data/apidocs/powershell/examples",
      "out": "./_site/api/powershell",
      "title": "PSWriteOffice Cmdlet Reference",
      "baseUrl": "/api/powershell",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "docsHome": "/docs/pswriteoffice/",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "injectCriticalCss": true
    },
    {
      "task": "xref-merge",
      "id": "merge-xref",
      "dependsOn": ["build-apidocs-word", "build-apidocs-excel", "build-apidocs-markdown", "build-apidocs-powershell"],
      "out": "./data/xrefmap.json",
      "mapFiles": [
        "./_site/api/word/xrefmap.json",
        "./_site/api/excel/xrefmap.json",
        "./_site/api/markdown/xrefmap.json",
        "./_site/api/powershell/xrefmap.json"
      ],
      "preferLast": true,
      "maxReferences": 90000,
      "maxDuplicates": 100
    },
    {
      "task": "build",
      "id": "build-site-xref-refresh",
      "dependsOn": "merge-xref",
      "config": "./site.json",
      "out": "./_site",
      "clean": false
    },
    {
      "task": "verify",
      "id": "verify-ci",
      "dependsOn": "build-site-xref-refresh",
      "modes": ["ci"],
      "config": "./site.json",
      "baseline": "./.powerforge/verify-baseline.json",
      "failOnNewWarnings": true,
      "failOnNavLint": true,
      "failOnThemeContract": true
    },
    {
      "task": "llms",
      "id": "build-llms",
      "dependsOn": "verify-ci",
      "siteRoot": "./_site",
      "apiIndex": "./_site/api/word/index.json",
      "apiBase": "/api",
      "name": "OfficeIMO",
      "license": "MIT",
      "targets": ".NET 8+, .NET 10+, .NET Standard 2.0, .NET Framework 4.7.2"
    },
    {
      "task": "sitemap",
      "id": "build-sitemap",
      "dependsOn": "build-llms",
      "siteRoot": "./_site",
      "baseUrl": "https://officeimo.com",
      "apiSitemap": "./_site/api/word/sitemap.xml",
      "includeNoIndexHtml": false,
      "noDefaultExclude": false,
      "excludePatterns": ["**/api-fragments/**", "**/*.scripts.html", "**/*.head.html"],
      "includeGeneratedHtmlRouteInXml": false,
      "json": true,
      "jsonOut": "./_site/sitemap/index.json",
      "html": true,
      "htmlOutput": "./_site/sitemap/index.html",
      "htmlTitle": "OfficeIMO Sitemap"
    },
    {
      "task": "optimize",
      "id": "optimize-site",
      "dependsOn": "build-sitemap",
      "skipModes": ["dev"],
      "siteRoot": "./_site",
      "config": "./site.json",
      "criticalCss": "./themes/officeimo/critical.css",
      "minifyHtml": true,
      "minifyCss": true,
      "minifyJs": true,
      "optimizeImages": true,
      "hashAssets": true,
      "hashExtensions": [".css", ".js"],
      "cacheHeaders": true,
      "cacheHeadersOut": "_headers"
    },
    {
      "task": "audit",
      "id": "audit-ci",
      "dependsOn": "optimize-site",
      "modes": ["ci"],
      "config": "./site.json",
      "siteRoot": "./_site",
      "baseline": "./.powerforge/audit-baseline.json",
      "failOnNewIssues": true,
      "navSelector": "header nav",
      "navCanonicalPath": "index.html",
      "navCanonicalRequired": true,
      "requiredRoutes": "/,/docs/,/404.html,/api/,/api/powershell/,/blog/,/showcase/,/products/word/"
    },
    {
      "task": "doctor",
      "id": "doctor-site",
      "dependsOn": "optimize-site",
      "skipModes": ["dev", "ci"],
      "config": "./site.json",
      "siteRoot": "./_site",
      "noBuild": true,
      "noVerify": true,
      "navSelector": "header nav",
      "navCanonicalPath": "index.html",
      "navCanonicalRequired": true,
      "requiredRoutes": "/,/docs/,/404.html,/api/,/api/powershell/,/blog/,/showcase/,/products/word/"
    }
  ]
}
