      "task": "xref-merge",
      "id": "merge-xref",
      "dependsOn": [
        "build-apidocs-word",
        "build-apidocs-excel",
        "build-apidocs-markdown",
        "build-apidocs-powerpoint",
        "build-apidocs-csv",
        "build-apidocs-visio",
        "build-apidocs-pdf",
        "build-apidocs-html",
        "build-apidocs-email",
        "build-apidocs-onenote",
        "build-apidocs-open-document",
        "build-apidocs-google-workspace",
        "build-apidocs-google-workspace-drive",
        "build-apidocs-google-workspace-auth",
        "build-apidocs-google-workspace-sync",
        "build-apidocs-reader",
        "build-apidocs-powershell"
      ],
      "out": "./data/xrefmap.json",
      "mapFiles": [
        "./_site/api/word/xrefmap.json",
        "./_site/api/excel/xrefmap.json",
        "./_site/api/markdown/xrefmap.json",
        "./_site/api/powerpoint/xrefmap.json",
        "./_site/api/csv/xrefmap.json",
        "./_site/api/visio/xrefmap.json",
        "./_site/api/pdf/xrefmap.json",
        "./_site/api/html/xrefmap.json",
        "./_site/api/email/xrefmap.json",
        "./_site/api/onenote/xrefmap.json",
        "./_site/api/open-document/xrefmap.json",
        "./_site/api/google-workspace/xrefmap.json",
        "./_site/api/google-workspace-drive/xrefmap.json",
        "./_site/api/google-workspace-auth/xrefmap.json",
        "./_site/api/google-workspace-sync/xrefmap.json",
        "./_site/api/reader/xrefmap.json",
        "./_site/api/powershell/xrefmap.json"
      ],
      "preferLast": true,
      "maxReferences": 90000,
      "maxDuplicates": 100
    },
    {
      "task": "build",
      "id": "build-site-xref-refresh",
      "dependsOn": ["merge-xref", "deploy-theme-css"],
      "config": "./site.json",
      "out": "./_site",
      "clean": false
    },
    {
      "task": "verify",
      "id": "verify-ci",
      "dependsOn": "build-site-xref-refresh",
      "modes": ["ci"],
      "config": "./site.json",
      "baseline": "./.powerforge/verify-baseline.json",
      "failOnNewWarnings": true,
      "failOnNavLint": true,
      "failOnThemeContract": true
    },
    {
      "task": "llms",
      "id": "build-llms",
      "dependsOn": "verify-ci",
      "siteRoot": "./_site",
      "apiIndexes": [
        "./_site/api/word/index.json",
        "./_site/api/excel/index.json",
        "./_site/api/powerpoint/index.json",
        "./_site/api/markdown/index.json",
        "./_site/api/csv/index.json",
        "./_site/api/visio/index.json",
        "./_site/api/pdf/index.json",
        "./_site/api/html/index.json",
        "./_site/api/email/index.json",
        "./_site/api/onenote/index.json",
        "./_site/api/open-document/index.json",
        "./_site/api/google-workspace/index.json",
        "./_site/api/google-workspace-drive/index.json",
        "./_site/api/google-workspace-auth/index.json",
        "./_site/api/google-workspace-sync/index.json",
        "./_site/api/reader/index.json",
        "./_site/api/powershell/index.json"
      ],
      "name": "OfficeIMO",
      "license": "MIT",
      "targets": ".NET 8+, .NET 10+, .NET Standard 2.0, .NET Framework 4.7.2"
    },
    {
      "task": "sitemap",
      "id": "build-sitemap",
      "dependsOn": "build-llms",
      "siteRoot": "./_site",
      "baseUrl": "https://officeimo.com",
      "apiSitemap": "./_site/api/word/sitemap.xml",
      "includeNoIndexHtml": false,
      "noDefaultExclude": false,
      "excludePatterns": [
        "**/api-fragments/**",
        "**/*.scripts.html",
        "**/*.head.html"
      ],
      "includeGeneratedHtmlRouteInXml": false,
      "json": true,
      "jsonOut": "./_site/sitemap/index.json",
      "html": true,
      "htmlOutput": "./_site/sitemap/index.html",
      "htmlTemplate": "./themes/officeimo/templates/sitemap.html",
      "htmlTitle": "OfficeIMO Sitemap"
    },
    {
      "task": "optimize",
      "id": "optimize-site",
      "dependsOn": "build-sitemap",
      "skipModes": ["dev"],
      "siteRoot": "./_site",
      "config": "./site.json",
      "criticalCss": "./themes/officeimo/critical.css",
      "minifyHtml": true,
      "minifyCss": true,
      "minifyJs": true,
      "optimizeImages": true,
      "hashAssets": true,
      "hashExtensions": [".css", ".js"],
      "hashExclude": [
        "**/apps/officeimo-converter/**",
        "**/assets/prism/components/**",
        "**/css/prism-theme.css"
      ],
      "cacheHeaders": true,
      "cacheHeadersOut": "_headers"
    },
    {
      "task": "exec",
      "id": "test-browser-converter",
      "dependsOn": "optimize-site",
      "command": "dotnet",
      "argsList": [
        "test",
        "./Apps/OfficeIMO.Web.Converter.Tests/OfficeIMO.Web.Converter.Tests.csproj",
        "-c",
        "Release",
        "--nologo",
        "--logger",
        "console;verbosity=minimal"
      ],
      "workingDirectory": "."
    },
    {
      "task": "dotnet-publish",
      "id": "publish-browser-converter",
      "dependsOn": "test-browser-converter",
      "project": "./Apps/OfficeIMO.Web.Converter/OfficeIMO.Web.Converter.csproj",
      "out": "./_temp/converter-publish",
      "configuration": "Release",
      "baseHref": "/apps/officeimo-converter/"
    },
    {
      "task": "overlay",
      "id": "overlay-browser-converter",
      "dependsOn": "publish-browser-converter",
      "source": "./_temp/converter-publish/wwwroot",
      "destination": "./_site/apps/officeimo-converter",
      "clean": true,
      "include": "**/*, *"
    },
    {
      "task": "exec",
      "id": "verify-browser-converter",
      "dependsOn": "overlay-browser-converter",
      "command": "pwsh",
      "argsList": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "./scripts/Test-ConverterPublish.ps1",
        "-SiteRoot",
        "./_site"
      ],
      "workingDirectory": "."
    },
    {
      "task": "agent-ready",
      "id": "agent-ready",
      "dependsOn": "verify-browser-converter",
      "skipModes": ["dev"],
      "operation": "prepare",
      "config": "./site.json",
      "siteRoot": "./_site",
      "output": "./_reports/agent-ready.json",
      "failOnFailures": true
    },
    {
      "task": "seo-doctor",
      "id": "seo-doctor-ci",
      "dependsOn": "agent-ready",
      "modes": ["ci"],
      "siteRoot": "./_site",
      "baseline": "./.powerforge/seo-baseline.json",
      "failOnNewIssues": true,
      "checkContentLeaks": true,
      "requireCanonical": true,
      "requireHreflang": true,
      "requireHreflangXDefault": true,
      "reportPath": "./_reports/seo-doctor.json",
      "summaryPath": "./_reports/seo-doctor.md",
      "backlogSummaryPath": "./_reports/seo-backlog-summary.json",
      "pageMetricsPath": "./_reports/seo-page-metrics.csv",
      "issuesCsvPath": "./_reports/seo-issues.csv"
    },
    {
      "task": "audit",
      "id": "audit-ci",
      "dependsOn": "seo-doctor-ci",
      "modes": ["ci"],
      "config": "./site.json",
      "siteRoot": "./_site",
      "baseline": "./.powerforge/audit-baseline.json",
      "failOnNewIssues": true,
      "navSelector": "header nav",
      "navCanonicalPath": "index.html",
      "navCanonicalRequired": true,
      "ignoreNav": "apps/officeimo-converter/**,sitemap/index.html",
      "requiredRoutes": "/,/docs/,/404.html,/api/,/api/powershell/,/api/powerpoint/,/api/csv/,/api/visio/,/api/pdf/,/api/html/,/api/email/,/api/onenote/,/api/open-document/,/api/reader/,/api/google-workspace/,/api/google-workspace-drive/,/api/google-workspace-auth/,/api/google-workspace-sync/,/blog/,/showcase/,/playground/,/products/word/,/products/pdf/,/products/email/,/products/onenote/,/products/open-document/,/products/google-workspace/,/products/html/"
    },
    {
      "task": "doctor",
      "id": "doctor-site",
      "dependsOn": "agent-ready",
      "skipModes": ["dev", "ci"],
      "config": "./site.json",
      "siteRoot": "./_site",
      "noBuild": true,
      "noVerify": true,
      "navSelector": "header nav",
      "navCanonicalPath": "index.html",
      "navCanonicalRequired": true,
      "ignoreNav": "apps/officeimo-converter/**,sitemap/index.html",
      "requiredRoutes": "/,/docs/,/404.html,/api/,/api/powershell/,/api/powerpoint/,/api/csv/,/api/visio/,/api/pdf/,/api/html/,/api/email/,/api/onenote/,/api/open-document/,/api/reader/,/api/google-workspace/,/api/google-workspace-drive/,/api/google-workspace-auth/,/api/google-workspace-sync/,/blog/,/showcase/,/playground/,/products/word/,/products/pdf/,/products/email/,/products/onenote/,/products/open-document/,/products/google-workspace/,/products/html/"
    }
  ]
