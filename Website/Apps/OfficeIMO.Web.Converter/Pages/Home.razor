@page "/"
@using System.Diagnostics
@using System.Text
@using OfficeIMO.Excel
@using OfficeIMO.Excel.Pdf
@using OfficeIMO.Markdown.Html
@using OfficeIMO.MarkdownRenderer
@using OfficeIMO.PowerPoint
@using OfficeIMO.PowerPoint.Pdf
@using OfficeIMO.Word
@using OfficeIMO.Word.Markdown
@using OfficeIMO.Word.Pdf
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>OfficeIMO Browser Converter</PageTitle>

<main class="ocx-shell">
    <div class="ocx-container">
        <section class="ocx-hero">
            <div>
                <p class="ocx-eyebrow">OfficeIMO WebAssembly</p>
                <h1 class="ocx-title">Try document conversions in your browser.</h1>
                <p class="ocx-lede">Run selected OfficeIMO engines locally: Office files to PDF, Markdown to HTML, HTML to Markdown, and Markdown to DOCX. The conversion map below shows the wider surface: Word, Markdown, HTML, Excel, Reader extraction, PDF operations, Markup exporters, CLI, PowerShell, MCP, and server workflows.</p>
                <div class="ocx-hero-actions">
                    <label class="ocx-button ocx-button--primary">
                        Choose Office file
                        <InputFile class="ocx-hidden-input" OnChange="HandleFileSelectedAsync" accept=".docx,.xlsx,.pptx" />
                    </label>
                    <button class="ocx-button" disabled="@(!CanConvert)" @onclick="ConvertAsync">Convert to PDF</button>
                    <button class="ocx-button" @onclick="ConvertMarkupAsync">Run text conversion</button>
                </div>
                <div class="ocx-sample-grid" aria-label="Sample documents">
                    @foreach (SampleDocument sample in Samples) {
                        <button type="button" @onclick="() => LoadSampleAsync(sample)">@sample.Label</button>
                    }
                    <button type="button" @onclick="LoadMarkdownSample">Sample Markdown</button>
                    <button type="button" @onclick="LoadHtmlSample">Sample HTML</button>
                </div>
            </div>

            <div class="ocx-status-strip" aria-label="Conversion status">
                <div class="ocx-status-card">
                    <span class="ocx-status-label">Runtime</span>
                    <span class="ocx-status-value">Static WASM</span>
                </div>
                <div class="ocx-status-card">
                    <span class="ocx-status-label">Live paths</span>
                    <span class="ocx-status-value">6 live routes</span>
                </div>
                <div class="ocx-status-card">
                    <span class="ocx-status-label">Output</span>
                    <span class="ocx-status-value">@CombinedStatus</span>
                </div>
            </div>
        </section>

        <section class="ocx-route-switcher" aria-label="Live conversion routes">
            <button type="button" class="ocx-route @(ActiveWorkspace == Workspace.OfficePdf ? "is-active" : "")" @onclick="() => ActiveWorkspace = Workspace.OfficePdf">
                <span>Office to PDF</span>
                <strong>DOCX XLSX PPTX</strong>
            </button>
            <button type="button" class="ocx-route @(ActiveWorkspace == Workspace.TextBridge ? "is-active" : "")" @onclick="() => ActiveWorkspace = Workspace.TextBridge">
                <span>Markdown and HTML</span>
                <strong>MD HTML DOCX</strong>
            </button>
        </section>

        @if (ActiveWorkspace == Workspace.OfficePdf) {
            <section class="ocx-workbench">
                <div class="ocx-panel">
                    <h2>Source document</h2>

                    <label class="ocx-dropzone">
                        <InputFile class="ocx-hidden-input" OnChange="HandleFileSelectedAsync" accept=".docx,.xlsx,.pptx" />
                        <span class="ocx-dropzone-inner">
                            <span class="ocx-drop-icon">PDF</span>
                            <strong>@(SelectedFile is null ? "Choose a DOCX, XLSX, or PPTX file" : SelectedFile.Name)</strong>
                            <span>@(SelectedFile is null ? "Files stay in this browser session." : $"{SelectedFile.FormatLabel} - {FormatBytes(SelectedFile.Size)}")</span>
                        </span>
                    </label>

                    <div class="ocx-field">
                        <label class="ocx-label" for="profile">Conversion profile</label>
                        <select id="profile" @bind="Profile">
                            <option value="balanced">Balanced fidelity</option>
                            <option value="fast">Fast preview</option>
                        </select>
                        <p class="ocx-hint">Fast preview limits Excel rows per sheet. Balanced fidelity keeps the converter defaults.</p>
                    </div>

                    <div class="ocx-checks">
                        <label><input type="checkbox" @bind="IncludeDiagnostics" /> Include conversion warnings on screen</label>
                        <label><input type="checkbox" @bind="PreviewPdf" /> Preview PDF after conversion</label>
                    </div>

                    <div class="ocx-matrix">
                        <div class="ocx-matrix-item">
                            <strong>DOCX</strong>
                            <span>Works for simple Word files. Rich documents can still hit the Unicode font embedding gap.</span>
                        </div>
                        <div class="ocx-matrix-item">
                            <strong>XLSX</strong>
                            <span>Uses workbook byte streams and the OfficeIMO.Excel.Pdf engine.</span>
                        </div>
                        <div class="ocx-matrix-item">
                            <strong>PPTX</strong>
                            <span>Uses presentation byte streams and the OfficeIMO.PowerPoint.Pdf engine.</span>
                        </div>
                    </div>
                </div>

                <div class="ocx-preview-column">
                    <div class="ocx-output">
                        <div class="ocx-output-head">
                            <h2>PDF output</h2>
                            @if (!string.IsNullOrEmpty(PdfUrl)) {
                                <a class="ocx-button ocx-button--primary" href="@PdfUrl" download="@OutputFileName">Download PDF</a>
                            }
                        </div>

                        <div class="ocx-output-stage">
                            @if (!string.IsNullOrEmpty(PdfUrl) && PreviewPdf) {
                                <iframe class="ocx-pdf-preview" src="@PdfUrl" title="Converted PDF preview"></iframe>
                            } else {
                                <div class="ocx-file-card">
                                    <p class="ocx-file-title">@StageTitle</p>
                                    <p class="ocx-muted">@StageMessage</p>
                                    @if (SelectedFile is not null) {
                                        <div class="ocx-file-meta">
                                            <span class="ocx-chip ocx-chip--cold">@SelectedFile.FormatLabel</span>
                                            <span class="ocx-chip">@FormatBytes(SelectedFile.Size)</span>
                                            <span class="ocx-chip @(IsBusy ? "ocx-chip--warn" : PdfBytes is null ? "" : "ocx-chip--good")">@OutputStatus</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        @if (IncludeDiagnostics) {
                            <div class="ocx-diagnostics">
                                @foreach (var item in Diagnostics) {
                                    <div class="ocx-diagnostic">
                                        <span class="ocx-dot @item.DotClass"></span>
                                        <div>
                                            <strong>@item.Title</strong>
                                            <span>@item.Message</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="ocx-code-card">
                        <h2>Engine path</h2>
                        <pre><code>@EnginePath</code></pre>
                    </div>
                </div>
            </section>
        } else {
            <section class="ocx-workbench ocx-workbench--text">
                <div class="ocx-panel">
                    <h2>Text bridge</h2>
                    <div class="ocx-field">
                        <label class="ocx-label" for="markupMode">Conversion route</label>
                        <select id="markupMode" @bind="MarkupMode">
                            <option value="markdown-html">Markdown to HTML</option>
                            <option value="html-markdown">HTML to Markdown</option>
                            <option value="markdown-docx">Markdown to DOCX</option>
                        </select>
                        <p class="ocx-hint">@MarkupModeHint</p>
                    </div>

                    <div class="ocx-field">
                        <label class="ocx-label" for="markupInput">Input</label>
                        <textarea id="markupInput" class="ocx-textarea" @bind="MarkupInput" @bind:event="oninput"></textarea>
                    </div>

                    <div class="ocx-hero-actions">
                        <button class="ocx-button ocx-button--primary" disabled="@MarkupBusy" @onclick="ConvertMarkupAsync">Convert</button>
                        <button class="ocx-button" disabled="@MarkupBusy" @onclick="LoadMarkdownSample">Markdown sample</button>
                        <button class="ocx-button" disabled="@MarkupBusy" @onclick="LoadHtmlSample">HTML sample</button>
                    </div>
                </div>

                <div class="ocx-preview-column">
                    <div class="ocx-output">
                        <div class="ocx-output-head">
                            <h2>@MarkupOutputTitle</h2>
                            @if (!string.IsNullOrEmpty(MarkupDownloadUrl)) {
                                <a class="ocx-button ocx-button--primary" href="@MarkupDownloadUrl" download="@MarkupDownloadFileName">@MarkupDownloadLabel</a>
                            }
                        </div>
                        <div class="ocx-output-stage ocx-output-stage--text">
                            @if (MarkupMode == "markdown-html" && !string.IsNullOrWhiteSpace(MarkupOutput)) {
                                <iframe class="ocx-html-preview" srcdoc="@MarkupOutput" title="Rendered Markdown HTML"></iframe>
                            } else {
                                <pre class="ocx-text-output"><code>@MarkupOutput</code></pre>
                            }
                        </div>
                        <div class="ocx-diagnostics">
                            @foreach (var item in MarkupDiagnostics) {
                                <div class="ocx-diagnostic">
                                    <span class="ocx-dot @item.DotClass"></span>
                                    <div>
                                        <strong>@item.Title</strong>
                                        <span>@item.Message</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="ocx-code-card">
                        <h2>Engine path</h2>
                        <pre><code>@MarkupEnginePath</code></pre>
                    </div>
                </div>
            </section>
        }

        <section class="ocx-capability-showcase" aria-label="OfficeIMO conversion map">
            <div class="ocx-section-head">
                <p class="ocx-eyebrow">Engine map</p>
                <h2>Conversion routes the engine can show.</h2>
                <p>These are real OfficeIMO families. Some are already live in this static browser app, while others belong in richer browser, CLI, PowerShell, MCP, plugin, skill, or server-backed workflows until the browser-safe path is proven.</p>
            </div>
            <div class="ocx-showcase-grid">
                @foreach (ConversionCapability capability in Capabilities) {
                    <article class="ocx-capability-card">
                        <span class="ocx-chip @capability.ChipClass">@capability.State</span>
                        <h3>@capability.Route</h3>
                        <p>@capability.Detail</p>
                        <code>@capability.Engine</code>
                    </article>
                }
            </div>
        </section>
    </div>
</main>

@code {
    private const long MaxUploadBytes = 25L * 1024L * 1024L;
    private const string DefaultMarkdown = """
# OfficeIMO conversion sample

This **Markdown** is rendered by `OfficeIMO.MarkdownRenderer`.

| Route | Status |
| --- | --- |
| Markdown to HTML | Live in browser |
| Markdown to DOCX | Live in browser |

- Local execution
- Downloadable output
- No server upload
""";

    private const string DefaultHtml = """
<article>
  <h1>OfficeIMO HTML sample</h1>
  <p>This HTML is converted to <strong>portable Markdown</strong>.</p>
  <ul>
    <li>Headings</li>
    <li>Lists</li>
    <li><a href="https://officeimo.com">Links</a></li>
  </ul>
</article>
""";

    private Workspace ActiveWorkspace { get; set; } = Workspace.OfficePdf;
    private SelectedOfficeFile? SelectedFile { get; set; }
    private byte[]? PdfBytes { get; set; }
    private string? PdfUrl { get; set; }
    private string OutputFileName { get; set; } = "officeimo-output.pdf";
    private string Profile { get; set; } = "balanced";
    private bool IncludeDiagnostics { get; set; } = true;
    private bool PreviewPdf { get; set; } = true;
    private bool IsBusy { get; set; }
    private List<ConverterDiagnostic> Diagnostics { get; } = new();

    private string MarkupMode { get; set; } = "markdown-html";
    private string MarkupInput { get; set; } = DefaultMarkdown;
    private string MarkupOutput { get; set; } = "Run a text conversion to see output here.";
    private string? MarkupDownloadUrl { get; set; }
    private string MarkupDownloadFileName { get; set; } = "officeimo-output.html";
    private string MarkupDownloadLabel { get; set; } = "Download HTML";
    private bool MarkupBusy { get; set; }
    private List<ConverterDiagnostic> MarkupDiagnostics { get; } = [
        new ConverterDiagnostic("Ready", "Choose a text conversion route and run it locally in WebAssembly.", "ocx-dot--good")
    ];

    private static IReadOnlyList<SampleDocument> Samples { get; } = [
        new SampleDocument("Sample DOCX", "samples/basic.docx", "OfficeIMO-Basic.docx", ".docx"),
        new SampleDocument("Sample XLSX", "samples/basic.xlsx", "OfficeIMO-Basic.xlsx", ".xlsx"),
        new SampleDocument("Sample PPTX", "samples/basic.pptx", "OfficeIMO-Basic.pptx", ".pptx")
    ];

    private static IReadOnlyList<ConversionCapability> Capabilities { get; } = [
        new ConversionCapability("DOCX to PDF", "Live browser", "WordDocument.Load(stream).SaveAsPdf(options)", "Current static WASM path with diagnostics for font and rich layout gaps.", "ocx-chip--good"),
        new ConversionCapability("XLSX to PDF", "Live browser", "ExcelDocument.Load(stream).SaveAsPdf(options)", "Workbook byte streams flow through OfficeIMO.Excel.Pdf with fast-preview options.", "ocx-chip--good"),
        new ConversionCapability("PPTX to PDF", "Live browser", "PowerPointPresentation.Open(stream).SaveAsPdf(options)", "Presentation byte streams flow through OfficeIMO.PowerPoint.Pdf.", "ocx-chip--good"),
        new ConversionCapability("Markdown to HTML", "Live browser", "MarkdownRenderer.RenderBodyHtml(markdown)", "Text conversion can run fully in static WebAssembly and render immediately.", "ocx-chip--good"),
        new ConversionCapability("HTML to Markdown", "Live browser", "html.ToMarkdown(HtmlToMarkdownOptions)", "HTML ingestion maps headings, lists, links, tables, and fallback HTML into Markdown.", "ocx-chip--good"),
        new ConversionCapability("Markdown to DOCX", "Live browser", "markdown.LoadFromMarkdown().SaveAsByteArray()", "Generates a downloadable Word package from typed Markdown conversion.", "ocx-chip--good"),
        new ConversionCapability("DOCX to Markdown", "Next browser route", "WordDocument.Load(stream).ToMarkdown(options)", "Supported by OfficeIMO.Word.Markdown; needs upload/output UI and asset sidecar handling.", "ocx-chip--warn"),
        new ConversionCapability("DOCX to HTML", "Next browser route", "WordDocument.Load(stream).ToHtmlViaMarkdown(options)", "Supported through the Markdown bridge; needs preview/download wiring.", "ocx-chip--warn"),
        new ConversionCapability("HTML to DOCX", "Next browser route", "html.LoadFromHtml().SaveAsByteArray()", "Completes the web-content bridge after HTML cleanup, styles, and image handling are validated.", "ocx-chip--warn"),
        new ConversionCapability("Markdown to PDF", "Next browser route", "markdown.LoadFromMarkdown().SaveAsPdf(options)", "Should reuse Markdown to Word first, then the PDF engine, with font diagnostics visible.", "ocx-chip--warn"),
        new ConversionCapability("Excel to CSV / JSON / HTML", "Engine route", "ExcelDocument.Load(stream).Worksheets", "Good browser demo for sheet preview, table extraction, CSV export, JSON records, and HTML tables.", "ocx-chip--cold"),
        new ConversionCapability("CSV / JSON to Excel", "Engine route", "CsvDocument / ExcelDocument", "Useful for drag-and-drop data cleanup, schema validation, and workbook generation.", "ocx-chip--cold"),
        new ConversionCapability("Reader extraction", "Engine route", "DocumentReader.Read(...)", "DOCX/PDF/HTML/JSON/XML/EPUB readers can feed Markdown, JSON, chunks, tables, and assets.", "ocx-chip--cold"),
        new ConversionCapability("PDF operations", "Engine route", "OfficeIMO.Pdf", "Split, merge, stamp, inspect, extract text/images, fill forms, metadata, and security workflows.", "ocx-chip--cold"),
        new ConversionCapability("Markup to Office", "Engine route", "OfficeIMO.Markup.* exporters", "One authoring model can export Word, Excel, PowerPoint, C#, and PowerShell emitters.", "ocx-chip--cold"),
        new ConversionCapability("Agent tools", "MCP / skill route", "OfficeIMO conversion tools", "Expose repeatable conversions and diagnostics through MCP tools, Codex skills, and packaging/release plugins.", "ocx-chip--cold")
    ];

    protected override void OnInitialized() {
        ApplyInitialRoute();
    }

    private void ApplyInitialRoute() {
        string route = GetQueryValue("route");
        if (string.IsNullOrWhiteSpace(route)) {
            return;
        }

        switch (route.Trim().ToLowerInvariant()) {
            case "markdown-html":
            case "html-markdown":
            case "markdown-docx":
                ActiveWorkspace = Workspace.TextBridge;
                MarkupMode = route.Trim().ToLowerInvariant();
                break;
            case "office-pdf":
            case "docx-pdf":
            case "xlsx-pdf":
            case "pptx-pdf":
                ActiveWorkspace = Workspace.OfficePdf;
                break;
        }
    }

    private string GetQueryValue(string name) {
        var uri = new Uri(Navigation.Uri);
        string query = uri.Query;
        if (query.Length <= 1) {
            return string.Empty;
        }

        foreach (string pair in query[1..].Split('&', StringSplitOptions.RemoveEmptyEntries)) {
            string[] parts = pair.Split('=', 2);
            string key = Uri.UnescapeDataString(parts[0]);
            if (!string.Equals(key, name, StringComparison.OrdinalIgnoreCase)) {
                continue;
            }

            return parts.Length == 2 ? Uri.UnescapeDataString(parts[1].Replace("+", " ")) : string.Empty;
        }

        return string.Empty;
    }

    private bool CanConvert => SelectedFile is not null && IsSupported(SelectedFile.Extension) && !IsBusy;
    private string OutputStatus => IsBusy ? "Converting" : PdfBytes is null ? "Waiting" : "Ready";
    private string CombinedStatus => IsBusy || MarkupBusy ? "Working" : PdfBytes is not null || !string.IsNullOrEmpty(MarkupDownloadUrl) ? "Ready" : "Waiting";
    private string StageTitle => IsBusy ? "Converting..." : PdfBytes is null ? "No PDF yet" : OutputFileName;
    private string StageMessage => IsBusy
        ? "OfficeIMO is converting the document inside WebAssembly."
        : PdfBytes is null
            ? "Choose a supported file, then convert it to generate a local PDF download."
            : $"Generated {FormatBytes(PdfBytes.Length)}.";

    private string EnginePath => SelectedFile?.Extension switch {
        ".docx" => "WordDocument.Load(stream).SaveAsPdf(options)",
        ".xlsx" => "ExcelDocument.Load(stream).SaveAsPdf(options)",
        ".pptx" => "PowerPointPresentation.Open(stream).SaveAsPdf(options)",
        _ => "Select a DOCX, XLSX, or PPTX file."
    };

    private string MarkupModeHint => MarkupMode switch {
        "markdown-html" => "Render Markdown to an HTML fragment using OfficeIMO.MarkdownRenderer.",
        "html-markdown" => "Convert HTML into portable Markdown using OfficeIMO.Markdown.Html.",
        "markdown-docx" => "Generate a downloadable DOCX package from Markdown using OfficeIMO.Word.Markdown.",
        _ => "Choose a conversion route."
    };

    private string MarkupOutputTitle => MarkupMode switch {
        "markdown-html" => "HTML preview",
        "html-markdown" => "Markdown output",
        "markdown-docx" => "DOCX output",
        _ => "Text output"
    };

    private string MarkupEnginePath => MarkupMode switch {
        "markdown-html" => "MarkdownRenderer.RenderBodyHtml(markdown, options)",
        "html-markdown" => "html.ToMarkdown(HtmlToMarkdownOptions.CreatePortableProfile())",
        "markdown-docx" => "markdown.LoadFromMarkdown(options).SaveAsByteArray()",
        _ => "Select a text conversion route."
    };

    private async Task HandleFileSelectedAsync(InputFileChangeEventArgs args) {
        ActiveWorkspace = Workspace.OfficePdf;
        await ResetPdfAsync();
        Diagnostics.Clear();

        IBrowserFile file = args.File;
        string extension = Path.GetExtension(file.Name).ToLowerInvariant();
        if (!IsSupported(extension)) {
            SelectedFile = null;
            Diagnostics.Add(new ConverterDiagnostic("Unsupported format", "Choose a DOCX, XLSX, or PPTX file.", "ocx-dot--bad"));
            return;
        }

        try {
            await using Stream source = file.OpenReadStream(MaxUploadBytes);
            using var buffer = new MemoryStream();
            await source.CopyToAsync(buffer);
            SelectedFile = new SelectedOfficeFile(file.Name, extension, FormatLabel(extension), file.Size, buffer.ToArray());
            OutputFileName = Path.GetFileNameWithoutExtension(file.Name) + ".pdf";
            Diagnostics.Add(new ConverterDiagnostic("File loaded", $"{file.Name} is ready for local conversion.", "ocx-dot--good"));
        } catch (IOException ex) {
            SelectedFile = null;
            Diagnostics.Add(new ConverterDiagnostic("File is too large", $"The playground limit is {FormatBytes(MaxUploadBytes)}. {ex.Message}", "ocx-dot--bad"));
        } catch (Exception ex) {
            SelectedFile = null;
            Diagnostics.Add(new ConverterDiagnostic("File load failed", ex.Message, "ocx-dot--bad"));
        }
    }

    private async Task LoadSampleAsync(SampleDocument sample) {
        ActiveWorkspace = Workspace.OfficePdf;
        await ResetPdfAsync();
        Diagnostics.Clear();

        try {
            byte[] bytes = await Http.GetByteArrayAsync(sample.Path);
            SelectedFile = new SelectedOfficeFile(sample.FileName, sample.Extension, FormatLabel(sample.Extension), bytes.LongLength, bytes);
            OutputFileName = Path.GetFileNameWithoutExtension(sample.FileName) + ".pdf";
            Diagnostics.Add(new ConverterDiagnostic("Sample loaded", $"{sample.FileName} is ready for local conversion.", "ocx-dot--good"));
        } catch (Exception ex) {
            SelectedFile = null;
            Diagnostics.Add(new ConverterDiagnostic("Sample load failed", ex.Message, "ocx-dot--bad"));
        }
    }

    private async Task ConvertAsync() {
        if (SelectedFile is null || IsBusy) {
            return;
        }

        IsBusy = true;
        await ResetPdfAsync();
        Diagnostics.RemoveAll(item => item.Title is "Conversion complete" or "Conversion failed" or "PDF validation");
        var stopwatch = Stopwatch.StartNew();

        try {
            ConversionOutput output = SelectedFile.Extension switch {
                ".docx" => ConvertWord(SelectedFile),
                ".xlsx" => ConvertExcel(SelectedFile),
                ".pptx" => ConvertPowerPoint(SelectedFile),
                _ => throw new NotSupportedException("Unsupported file extension.")
            };

            stopwatch.Stop();
            PdfBytes = output.Bytes;
            if (!LooksLikePdf(PdfBytes)) {
                throw new InvalidDataException("The conversion returned bytes that do not start with a PDF header.");
            }

            PdfUrl = await JS.InvokeAsync<string>("officeimoConverter.createObjectUrl", PdfBytes, "application/pdf");
            Diagnostics.Add(new ConverterDiagnostic("Conversion complete", $"Generated {FormatBytes(PdfBytes.Length)} in {stopwatch.ElapsedMilliseconds} ms.", "ocx-dot--good"));
            Diagnostics.Add(new ConverterDiagnostic("PDF validation", "The output starts with the %PDF header.", "ocx-dot--good"));

            foreach (string warning in output.Warnings.Take(8)) {
                Diagnostics.Add(new ConverterDiagnostic("Conversion warning", warning, "ocx-dot--warn"));
            }
        } catch (Exception ex) {
            PdfBytes = null;
            Diagnostics.Add(new ConverterDiagnostic("Conversion failed", DescribeFailure(ex), "ocx-dot--bad"));
        } finally {
            IsBusy = false;
        }
    }

    private async Task LoadMarkdownSample() {
        ActiveWorkspace = Workspace.TextBridge;
        await ResetMarkupAsync();
        MarkupMode = "markdown-html";
        MarkupInput = DefaultMarkdown;
        MarkupOutput = "Run Markdown to HTML, HTML to Markdown, or Markdown to DOCX.";
        MarkupDiagnostics.Clear();
        MarkupDiagnostics.Add(new ConverterDiagnostic("Sample loaded", "Markdown sample is ready for local conversion.", "ocx-dot--good"));
    }

    private async Task LoadHtmlSample() {
        ActiveWorkspace = Workspace.TextBridge;
        await ResetMarkupAsync();
        MarkupMode = "html-markdown";
        MarkupInput = DefaultHtml;
        MarkupOutput = "Run HTML to Markdown to see portable Markdown output.";
        MarkupDiagnostics.Clear();
        MarkupDiagnostics.Add(new ConverterDiagnostic("Sample loaded", "HTML sample is ready for local conversion.", "ocx-dot--good"));
    }

    private async Task ConvertMarkupAsync() {
        if (MarkupBusy) {
            return;
        }

        ActiveWorkspace = Workspace.TextBridge;
        MarkupBusy = true;
        await ResetMarkupAsync();
        MarkupDiagnostics.Clear();
        var stopwatch = Stopwatch.StartNew();

        try {
            if (string.IsNullOrWhiteSpace(MarkupInput)) {
                throw new InvalidOperationException("Provide Markdown or HTML input first.");
            }

            switch (MarkupMode) {
                case "markdown-html":
                    await ConvertMarkdownToHtmlAsync();
                    break;
                case "html-markdown":
                    await ConvertHtmlToMarkdownAsync();
                    break;
                case "markdown-docx":
                    await ConvertMarkdownToDocxAsync();
                    break;
                default:
                    throw new NotSupportedException("Unknown text conversion route.");
            }

            stopwatch.Stop();
            MarkupDiagnostics.Add(new ConverterDiagnostic("Conversion complete", $"Generated output in {stopwatch.ElapsedMilliseconds} ms.", "ocx-dot--good"));
        } catch (Exception ex) {
            MarkupOutput = ex.Message;
            MarkupDiagnostics.Add(new ConverterDiagnostic("Conversion failed", ex.Message, "ocx-dot--bad"));
        } finally {
            MarkupBusy = false;
        }
    }

    private async Task ConvertMarkdownToHtmlAsync() {
        var options = MarkdownRendererPresets.CreateStrictMinimalPortable();
        string html = MarkdownRenderer.RenderBodyHtml(MarkupInput, options);
        MarkupOutput = html;
        MarkupDownloadFileName = "officeimo-markdown.html";
        MarkupDownloadLabel = "Download HTML";
        await CreateTextDownloadAsync(html, "text/html;charset=utf-8");
    }

    private async Task ConvertHtmlToMarkdownAsync() {
        var options = HtmlToMarkdownOptions.CreatePortableProfile();
        string markdown = MarkupInput.ToMarkdown(options);
        MarkupOutput = markdown;
        MarkupDownloadFileName = "officeimo-html.md";
        MarkupDownloadLabel = "Download Markdown";
        await CreateTextDownloadAsync(markdown, "text/markdown;charset=utf-8");
    }

    private async Task ConvertMarkdownToDocxAsync() {
        using WordDocument document = MarkupInput.LoadFromMarkdown(new MarkdownToWordOptions {
            PreferNarrativeSingleLineDefinitions = true
        });

        byte[] bytes = document.SaveAsByteArray();
        MarkupOutput = $"DOCX generated: {FormatBytes(bytes.Length)}. Use the download button to save it locally.";
        MarkupDownloadFileName = "officeimo-markdown.docx";
        MarkupDownloadLabel = "Download DOCX";
        MarkupDownloadUrl = await JS.InvokeAsync<string>(
            "officeimoConverter.createObjectUrl",
            bytes,
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document");
    }

    private async Task CreateTextDownloadAsync(string text, string contentType) {
        byte[] bytes = Encoding.UTF8.GetBytes(text);
        MarkupDownloadUrl = await JS.InvokeAsync<string>("officeimoConverter.createObjectUrl", bytes, contentType);
    }

    private static ConversionOutput ConvertWord(SelectedOfficeFile file) {
        using var stream = new MemoryStream(file.Bytes, writable: false);
        using WordDocument document = WordDocument.Load(stream, readOnly: true);
        var options = new PdfSaveOptions {
            Title = Path.GetFileNameWithoutExtension(file.Name),
            IncludePageNumbers = true
        };

        byte[] bytes = document.SaveAsPdf(options);
        return new ConversionOutput(bytes, options.Warnings.Select(warning => warning.ToString()).ToArray());
    }

    private ConversionOutput ConvertExcel(SelectedOfficeFile file) {
        using var stream = new MemoryStream(file.Bytes, writable: false);
        using ExcelDocument document = ExcelDocument.Load(stream, readOnly: true);
        var options = new ExcelPdfSaveOptions {
            MaxRowsPerSheet = Profile == "fast" ? 250 : null
        };

        byte[] bytes = document.SaveAsPdf(options);
        return new ConversionOutput(bytes, options.Warnings.Select(warning => warning.ToString()).ToArray());
    }

    private static ConversionOutput ConvertPowerPoint(SelectedOfficeFile file) {
        using var stream = new MemoryStream(file.Bytes, writable: false);
        using PowerPointPresentation presentation = PowerPointPresentation.Open(stream, readOnly: true);
        var options = new PowerPointPdfSaveOptions {
            WarnOnPictureAspectRatioDistortion = true
        };

        byte[] bytes = presentation.SaveAsPdf(options);
        return new ConversionOutput(bytes, options.Warnings.Select(warning => warning.Code + ": " + warning.Message).ToArray());
    }

    private async Task ResetPdfAsync() {
        PdfBytes = null;
        if (!string.IsNullOrEmpty(PdfUrl)) {
            await JS.InvokeVoidAsync("officeimoConverter.revokeObjectUrl", PdfUrl);
            PdfUrl = null;
        }
    }

    private async Task ResetMarkupAsync() {
        if (!string.IsNullOrEmpty(MarkupDownloadUrl)) {
            await JS.InvokeVoidAsync("officeimoConverter.revokeObjectUrl", MarkupDownloadUrl);
            MarkupDownloadUrl = null;
        }
    }

    private static bool IsSupported(string extension) =>
        extension is ".docx" or ".xlsx" or ".pptx";

    private static string FormatLabel(string extension) => extension switch {
        ".docx" => "Word DOCX",
        ".xlsx" => "Excel XLSX",
        ".pptx" => "PowerPoint PPTX",
        _ => "Unknown"
    };

    private static bool LooksLikePdf(byte[] bytes) =>
        bytes.Length >= 4 && bytes[0] == 0x25 && bytes[1] == 0x50 && bytes[2] == 0x44 && bytes[3] == 0x46;

    private static string FormatBytes(long bytes) {
        string[] units = ["B", "KB", "MB", "GB"];
        double value = bytes;
        int unit = 0;
        while (value >= 1024 && unit < units.Length - 1) {
            value /= 1024;
            unit++;
        }

        return unit == 0 ? $"{bytes} B" : $"{value:0.##} {units[unit]}";
    }

    private static string DescribeFailure(Exception ex) {
        if (ex.GetType().Name.Contains("PdfTextEncodingPreflightException", StringComparison.Ordinal)) {
            return "This Word document contains text that needs embedded Unicode font support before it can be exported in the browser. " + ex.Message;
        }

        return ex.Message;
    }

    private enum Workspace {
        OfficePdf,
        TextBridge
    }

    private sealed record SelectedOfficeFile(string Name, string Extension, string FormatLabel, long Size, byte[] Bytes);
    private sealed record SampleDocument(string Label, string Path, string FileName, string Extension);
    private sealed record ConversionOutput(byte[] Bytes, IReadOnlyList<string> Warnings);
    private sealed record ConverterDiagnostic(string Title, string Message, string DotClass);
    private sealed record ConversionCapability(string Route, string State, string Engine, string Detail, string ChipClass);
}
