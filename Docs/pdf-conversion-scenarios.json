      "expectedSimplifications": [
        "unsupported slide shapes and overflowing text boxes record converter warnings"
      ],
      "expectedWarnings": [],
      "visualReviewFiles": [
        "native-powerpoint-dense-layout.pdf"
      ],
      "proof": {
        "hash": true,
        "textMarkers": [
          "Dense Layout Gate",
          "Flow"
        ],
        "logicalSignals": [
          "page-geometry",
          "text",
          "images"
        ],
        "visualPages": 1,
        "validatorEvidence": [
          "PdfInspector",
          "PdfReadDocument",
          "optional Poppler raster baseline"
        ]
      }
    },
    {
      "id": "converter-multilingual-typography",
      "path": "cross-converter-typography-to-pdf",
      "converter": "OfficeIMO.Word.Pdf, OfficeIMO.Excel.Pdf, OfficeIMO.Markdown.Pdf, OfficeIMO.Html.Pdf, OfficeIMO.PowerPoint.Pdf",
      "sourceFormat": "word/excel/markdown/html/powerpoint",
      "targetFormat": "pdf",
      "status": "supported",
      "sourceFeatures": [
        "embedded-truetype-font-options",
        "unicode-polish-text",
        "unicode-greek-text",
        "unicode-cyrillic-text",
        "tables",
        "extractable-text"
      ],
      "expectedSimplifications": [
        "visual layout remains adapter-specific while the shared typography contract requires Type0 Identity-H embedded font output and extractable Unicode text"
      ],
      "expectedWarnings": [],
      "visualReviewFiles": [
        "multilingual-word-to-pdf.pdf",
        "multilingual-excel-to-pdf.pdf",
        "multilingual-markdown-to-pdf.pdf",
        "multilingual-html-to-pdf.pdf",
        "multilingual-powerpoint-to-pdf.pdf"
      ],
      "proof": {
        "hash": true,
        "textMarkers": [
          "Converter typography report",
          "Zażółć gęślą jaźń",
          "Ελλάδα",
          "Київ"
        ],
        "logicalSignals": [
          "type0-font",
          "identity-h-encoding",
          "to-unicode-map",
          "font-file2",
          "extractable-unicode"
        ],
        "visualPages": 5,
        "validatorEvidence": [
          "PdfReadDocument",
          "raw PDF font-resource checks",
          "visual review gallery"
        ]
      }
    },
    {
      "id": "pdf-logical-readback",
      "path": "pdf-to-logical",
      "converter": "OfficeIMO.Pdf",
      "sourceFormat": "pdf",
      "targetFormat": "logical-read-model",
      "status": "supported",
      "sourceFeatures": [
        "headings",
        "paragraphs",
        "lists",
        "tables",
        "links",
        "images"
      ],
      "expectedSimplifications": [
        "logical readback is parser-supported and does not OCR scanned pages"
      ],
      "expectedWarnings": [],
      "visualReviewFiles": [
        "pdf-to-html-logical-source.pdf"
      ],
      "proof": {
        "hash": true,
        "textMarkers": [
          "Logical PDF sample",
          "Detected logical bullet"
        ],
        "logicalSignals": [
          "headings",
          "paragraphs",
          "list-items",
          "tables",
          "links",
          "images"
        ],
        "visualPages": 1,
        "validatorEvidence": [
          "PdfLogicalDocument",
          "PdfReadDocument"
        ]
      }
    },
    {
      "id": "pdf-to-html-positioned-review",
      "path": "pdf-to-html",
      "converter": "OfficeIMO.Html.Pdf",
      "sourceFormat": "pdf",
      "targetFormat": "html",
      "status": "supported",
      "sourceFeatures": [
        "logical-text",
        "headings",
        "tables",
        "links",
        "image-placeholders",
