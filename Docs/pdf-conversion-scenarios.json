      ],
      "expectedSimplifications": [
        "positioned review HTML is an inspection surface, not a full PDF renderer"
      ],
      "expectedWarnings": [],
      "visualReviewFiles": [
        "pdf-to-html-logical-source.pdf",
        "pdf-to-html-positioned-review.html"
      ],
      "proof": {
        "hash": true,
        "textMarkers": [
          "Logical PDF sample",
          "Logical Heading"
        ],
        "logicalSignals": [
          "html-page-containers",
          "positioned-text",
          "safe-links",
          "image-placeholders"
        ],
        "visualPages": 1,
        "validatorEvidence": [
          "PdfHtmlConverter",
          "PdfLogicalDocument"
        ]
      }
    },
    {
      "id": "pdf-table-import-editable-office",
      "path": "pdf-to-editable-office-tables",
      "converter": "OfficeIMO.Word.Pdf, OfficeIMO.Excel.Pdf, OfficeIMO.PowerPoint.Pdf",
      "sourceFormat": "pdf",
      "targetFormat": "docx/xlsx/pptx",
      "status": "supported",
      "sourceFeatures": [
