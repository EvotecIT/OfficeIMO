{
  "version": 1,
  "description": "OfficeIMO PDF conversion proof scenarios. The manifest is consumed by tests and the PDF visual review gallery so converter coverage stays observable.",
  "scenarios": [
    {
      "id": "word-native-report",
      "path": "word-to-pdf",
      "converter": "OfficeIMO.Word.Pdf",
      "sourceFormat": "word",
      "targetFormat": "pdf",
      "status": "supported",
      "sourceFeatures": [
        "headings",
        "table-of-contents",
        "rich-runs",
        "lists",
        "tables",
        "images",
        "checkbox-form-fields",
        "header-content"
      ],
      "expectedSimplifications": [
        "complex unsupported Word content records converter warnings rather than blocking export"
      ],
      "expectedWarnings": [],
      "visualReviewFiles": [
        "native-word-report.pdf"
      ],
      "proof": {
        "hash": true,
        "textMarkers": [
          "Native Word PDF Visual Gate",
          "Native evidence table"
        ],
        "logicalSignals": [
          "headings",
          "outlines",
          "links",
          "form-fields"
        ],
        "visualPages": 1,
        "validatorEvidence": [
          "PdfInspector",
          "PdfLogicalDocument",
          "optional Poppler raster baseline"
        ]
      }
    },
    {
      "id": "excel-native-daily-workbook",
      "path": "excel-to-pdf",
      "converter": "OfficeIMO.Excel.Pdf",
      "sourceFormat": "excel",
      "targetFormat": "pdf",
      "status": "supported",
      "sourceFeatures": [
        "multiple-sheets",
        "cell-formatting",
        "hyperlinks",
        "images",
        "charts",
        "print-area",
        "header-footer",
        "hidden-rows-columns"
      ],
      "expectedSimplifications": [
        "unsupported workbook constructs are represented through warnings or skipped from the visible export"
      ],
      "expectedWarnings": [],
      "visualReviewFiles": [
        "native-excel-daily-workbook.pdf"
      ],
      "proof": {
        "hash": true,
        "textMarkers": [
          "Daily Excel PDF Gate",
          "Revenue Chart",
          "Details Target"
        ],
        "logicalSignals": [
          "page-count",
          "outlines",
          "links",
          "images"
        ],
        "visualPages": 2,
        "validatorEvidence": [
          "PdfInspector",
          "PdfLogicalDocument",
          "PdfImageExtractor",
          "optional Poppler raster baseline"
        ]
      }
    },
    {
      "id": "markdown-technical-document",
      "path": "markdown-to-pdf",
      "converter": "OfficeIMO.Markdown.Pdf",
      "sourceFormat": "markdown",
      "targetFormat": "pdf",
      "status": "supported",
      "sourceFeatures": [
        "front-matter",
        "headings",
        "links",
        "local-images",
        "lists",
        "tables",
        "quotes",
        "code-blocks"
      ],
      "expectedSimplifications": [
        "remote images require caller-supplied resolver and produce warnings when unresolved"
      ],
      "expectedWarnings": [],
      "visualReviewFiles": [
        "markdown-technical-document.pdf"
      ],
      "proof": {
        "hash": true,
        "textMarkers": [
          "Markdown PDF Visual Gate",
          "Export coverage"
        ],
        "logicalSignals": [
          "headings",
          "links",
          "images",
          "tables"
        ],
        "visualPages": 1,
        "validatorEvidence": [
          "PdfReadDocument",
          "PdfLogicalDocument",
          "optional Poppler raster baseline"
        ]
      }
    },
    {
      "id": "html-document-profile",
      "path": "html-to-pdf",
      "converter": "OfficeIMO.Html.Pdf",
      "sourceFormat": "html",
      "targetFormat": "pdf",
      "status": "supported",
      "sourceFeatures": [
        "headings",
        "links",
        "embedded-images",
        "tables",
        "page-breaks",
        "document-profile"
      ],
      "expectedSimplifications": [
        "document profile follows the Word HTML bridge and is not a browser/CSS renderer"
      ],
      "expectedWarnings": [],
      "visualReviewFiles": [
        "practical-html.pdf"
      ],
      "proof": {
        "hash": true,
        "textMarkers": [
          "Practical HTML",
          "Second page marker"
        ],
        "logicalSignals": [
          "page-count",
          "links",
          "images",
          "tables"
        ],
        "visualPages": 2,
        "validatorEvidence": [
          "PdfInspector",
          "PdfLogicalDocument",
          "PdfImageExtractor"
        ]
      }
    },
    {
      "id": "powerpoint-native-dense-layout",
      "path": "powerpoint-to-pdf",
      "converter": "OfficeIMO.PowerPoint.Pdf",
      "sourceFormat": "powerpoint",
      "targetFormat": "pdf",
      "status": "supported",
      "sourceFeatures": [
        "slide-size",
        "text-boxes",
        "bullets",
        "tables",
        "images",
        "charts",
        "backgrounds"
