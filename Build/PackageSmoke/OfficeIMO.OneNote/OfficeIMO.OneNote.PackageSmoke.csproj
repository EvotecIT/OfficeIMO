<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <TargetFrameworks Condition="$([MSBuild]::IsOsPlatform('Windows'))">$(TargetFrameworks);net472</TargetFrameworks>
    <EnableOfficeIMOOneNotePackageSmoke Condition="'$(EnableOfficeIMOOneNotePackageSmoke)' == ''">false</EnableOfficeIMOOneNotePackageSmoke>
    <OfficeIMOOneNotePackageVersion Condition="'$(OfficeIMOOneNotePackageVersion)' == ''">2.0.1</OfficeIMOOneNotePackageVersion>
    <IsPackable>false</IsPackable>
    <LangVersion>Latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup Condition="'$(EnableOfficeIMOOneNotePackageSmoke)' == 'true'">
    <PackageReference Include="OfficeIMO.OneNote" Version="[$(OfficeIMOOneNotePackageVersion)]" />
    <PackageReference Include="OfficeIMO.OneNote.Markdown" Version="[$(OfficeIMOOneNotePackageVersion)]" />
    <PackageReference Include="OfficeIMO.OneNote.Html" Version="[$(OfficeIMOOneNotePackageVersion)]" />
    <PackageReference Include="OfficeIMO.OneNote.Pdf" Version="[$(OfficeIMOOneNotePackageVersion)]" />
    <PackageReference Include="OfficeIMO.Reader" Version="[$(OfficeIMOOneNotePackageVersion)]" />
    <PackageReference Include="OfficeIMO.Reader.OneNote" Version="[$(OfficeIMOOneNotePackageVersion)]" />
  </ItemGroup>

  <Target Name="RequirePackageSmokeOptIn" BeforeTargets="CoreCompile"
          Condition="'$(EnableOfficeIMOOneNotePackageSmoke)' != 'true'">
    <Error Text="Set EnableOfficeIMOOneNotePackageSmoke=true and restore from a feed containing the packed OfficeIMO.OneNote package family." />
  </Target>
</Project>
